+static bool os_popenRead(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  if (args.length() != 1) {
+    JS_ReportErrorASCII(cx, "os.popenRead requires 1 argument");
+    return false;
+  }
+
+  RootedString commandStr(cx, ToString(cx, args[0]));
+  if (!commandStr) {
+    return false;
+  }
+  UniqueChars command = JS_EncodeStringToUTF8(cx, commandStr);
+  if (!command) {
+    return false;
+  }
+
+  FILE* pipe = popen(command.get(), "r");
+  if (!pipe) {
+    JS_ReportErrorUTF8(cx, "popen failed: errno %d", errno);
+    return false;
+  }
+
+  std::string output;
+  char buffer[4096];
+  while (fgets(buffer, sizeof(buffer), pipe)) {
+    output.append(buffer);
+  }
+  int status = pclose(pipe);
+#ifndef XP_WIN
+  if (WIFEXITED(status)) {
+    status = WEXITSTATUS(status);
+  }
+#endif
+
+  RootedObject obj(cx, JS_NewPlainObject(cx));
+  RootedString out(cx, JS_NewStringCopyN(cx, output.data(), output.size()));
+  if (!obj || !out || !JS_DefineProperty(cx, obj, "output", out, JSPROP_ENUMERATE) ||
+      !JS_DefineProperty(cx, obj, "status", status, JSPROP_ENUMERATE)) {
+    return false;
+  }
+  args.rval().setObject(*obj);
+  return true;
+}
