+struct KandeloZlibState {
+  z_stream stream{};
+  bool deflate = false;
+};
+
+static void KandeloZlibDestroy(KandeloZlibState* state) {
+  if (!state) return;
+  if (state->deflate) deflateEnd(&state->stream);
+  else inflateEnd(&state->stream);
+  js_delete(state);
+}
+
+static void KandeloZlibFinalize(JS::GCContext* gcx, JSObject* obj) {
+  auto* state =
+      static_cast<KandeloZlibState*>(JS::GetReservedSlot(obj, 0).toPrivate());
+  KandeloZlibDestroy(state);
+}
+
+static const JSClassOps KandeloZlibClassOps = {
+    nullptr, nullptr, nullptr, nullptr, nullptr, nullptr,
+    KandeloZlibFinalize, nullptr, nullptr, nullptr};
+
+static const JSClass KandeloZlibClass = {
+    "KandeloNodeZlib",
+    JSCLASS_HAS_RESERVED_SLOTS(1) | JSCLASS_FOREGROUND_FINALIZE,
+    &KandeloZlibClassOps,
+};
+
+static bool KandeloZlibRun(JSContext* cx, KandeloZlibState* state,
+                           const uint8_t* input, size_t inputLen, bool finish,
+                           MutableHandleValue rval) {
+  state->stream.next_in = const_cast<Bytef*>(input);
+  state->stream.avail_in = uInt(inputLen);
+  const int flush = finish ? Z_FINISH : Z_NO_FLUSH;
+  std::vector<uint8_t> out;
+  uint8_t chunk[64 * 1024];
+  for (;;) {
+    state->stream.next_out = chunk;
+    state->stream.avail_out = sizeof(chunk);
+    int rc = state->deflate ? deflate(&state->stream, flush)
+                            : inflate(&state->stream, flush);
+    size_t produced = sizeof(chunk) - state->stream.avail_out;
+    out.insert(out.end(), chunk, chunk + produced);
+    if (rc == Z_STREAM_END) break;
+    if (rc == Z_BUF_ERROR && state->stream.avail_in == 0 && produced == 0) break;
+    if (rc != Z_OK) {
+      JS_ReportErrorASCII(cx, "%s", state->stream.msg ? state->stream.msg : "zlib error");
+      return false;
+    }
+    if (!finish && state->stream.avail_in == 0) break;
+  }
+  RootedObject result(cx, KandeloNewUint8ArrayCopy(
+                              cx, out.empty() ? nullptr : out.data(), out.size()));
+  if (!result) {
+    return false;
+  }
+  rval.setObject(*result);
+  return true;
+}
+
+static KandeloZlibState* KandeloZlibFromThis(JSContext* cx,
+                                             const CallArgs& args) {
+  if (!args.thisv().isObject()) {
+    JS_ReportErrorASCII(cx, "invalid zlib receiver");
+    return nullptr;
+  }
+  RootedObject obj(cx, &args.thisv().toObject());
+  if (JS::GetClass(obj) != &KandeloZlibClass) {
+    JS_ReportErrorASCII(cx, "invalid zlib receiver");
+    return nullptr;
+  }
+  auto* state =
+      static_cast<KandeloZlibState*>(JS::GetReservedSlot(obj, 0).toPrivate());
+  if (!state) {
+    JS_ReportErrorASCII(cx, "invalid zlib state");
+  }
+  return state;
+}
+
+static bool KandeloZlibWrite(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  KandeloZlibState* state = KandeloZlibFromThis(cx, args);
+  if (!state) {
+    return false;
+  }
+  if (args.length() < 1) {
+    JS_ReportErrorASCII(cx, "zlib.write requires input");
+    return false;
+  }
+  std::vector<uint8_t> input;
+  if (!KandeloValueToBytes(cx, args[0], &input)) {
+    return false;
+  }
+  bool finish = args.length() >= 2 && JS::ToBoolean(args[1]);
+  return KandeloZlibRun(cx, state, input.data(), input.size(), finish,
+                        args.rval());
+}
+
+static bool KandeloMakeZlib(JSContext* cx, bool deflateMode, int windowBits,
+                            int level, MutableHandleValue rval) {
+  auto* state = js_new<KandeloZlibState>();
+  if (!state) {
+    JS_ReportOutOfMemory(cx);
+    return false;
+  }
+  state->deflate = deflateMode;
+  int rc = deflateMode
+               ? deflateInit2(&state->stream, level, Z_DEFLATED, windowBits, 8,
+                              Z_DEFAULT_STRATEGY)
+               : inflateInit2(&state->stream, windowBits);
+  if (rc != Z_OK) {
+    js_delete(state);
+    JS_ReportErrorASCII(cx, "zlib init failed");
+    return false;
+  }
+  RootedObject obj(cx, JS_NewObject(cx, &KandeloZlibClass));
+  if (!obj) {
+    KandeloZlibDestroy(state);
+    return false;
+  }
+  JS::SetReservedSlot(obj, 0, JS::PrivateValue(state));
+  if (!JS_DefineFunction(cx, obj, "write", KandeloZlibWrite, 2, 0)) {
+    return false;
+  }
+  rval.setObject(*obj);
+  return true;
+}
+
+static int KandeloNormalizeZlibLevel(JSContext* cx, HandleValue value) {
+  if (value.isUndefined()) return Z_DEFAULT_COMPRESSION;
+  int32_t level;
+  if (!JS::ToInt32(cx, value, &level)) return Z_DEFAULT_COMPRESSION;
+  if (level != Z_DEFAULT_COMPRESSION && (level < 0 || level > 9)) {
+    JS_ReportErrorASCII(cx, "zlib level must be -1 or 0..9");
+    return Z_DEFAULT_COMPRESSION;
+  }
+  return level;
+}
