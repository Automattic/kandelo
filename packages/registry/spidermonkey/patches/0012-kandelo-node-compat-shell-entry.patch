+static JSObject* KandeloNewUint8ArrayCopy(JSContext* cx, const uint8_t* data,
+                                          size_t len) {
+  RootedObject obj(cx, JS_NewUint8Array(cx, len));
+  if (!obj) {
+    return nullptr;
+  }
+  auto& ta = obj->as<TypedArrayObject>();
+  if (ta.isSharedMemory()) {
+    JS_ReportErrorASCII(cx, "cannot write native bytes into shared memory");
+    return nullptr;
+  }
+  if (len > 0) {
+    memcpy(ta.dataPointerUnshared(), data, len);
+  }
+  return obj;
+}
+
+static bool KandeloValueToBytes(JSContext* cx, HandleValue value,
+                                std::vector<uint8_t>* out) {
+  out->clear();
+  if (value.isString()) {
+    RootedString strValue(cx, value.toString());
+    UniqueChars str = JS_EncodeStringToUTF8(cx, strValue);
+    if (!str) {
+      return false;
+    }
+    size_t len = strlen(str.get());
+    out->assign(reinterpret_cast<const uint8_t*>(str.get()),
+                reinterpret_cast<const uint8_t*>(str.get()) + len);
+    return true;
+  }
+  if (!value.isObject()) {
+    JS_ReportErrorASCII(cx, "expected string, ArrayBuffer, or typed array");
+    return false;
+  }
+
+  RootedObject obj(cx, &value.toObject());
+  JS::AutoCheckCannotGC nogc;
+  bool isShared = false;
+  if (JS_IsArrayBufferViewObject(obj)) {
+    uint8_t* data =
+        static_cast<uint8_t*>(JS_GetArrayBufferViewData(obj, &isShared, nogc));
+    size_t len = JS_GetArrayBufferViewByteLength(obj);
+    if (isShared) {
+      JS_ReportErrorASCII(cx, "shared typed arrays are not supported here");
+      return false;
+    }
+    out->assign(data, data + len);
+    return true;
+  }
+  if (JS::IsArrayBufferObject(obj)) {
+    uint8_t* data = JS::GetArrayBufferData(obj, &isShared, nogc);
+    size_t len = JS::GetArrayBufferByteLength(obj);
+    if (isShared) {
+      JS_ReportErrorASCII(cx, "shared ArrayBuffer is not supported here");
+      return false;
+    }
+    out->assign(data, data + len);
+    return true;
+  }
+  JS_ReportErrorASCII(cx, "expected string, ArrayBuffer, or typed array");
+  return false;
+}
+
+static bool KandeloGetString(JSContext* cx, HandleValue value,
+                             UniqueChars* out) {
+  RootedString str(cx, JS::ToString(cx, value));
+  if (!str) {
+    return false;
+  }
+  *out = JS_EncodeStringToUTF8(cx, str);
+  return *out != nullptr;
+}
