+static JSObject* KandeloResolvedPromise(JSContext* cx, HandleValue value) {
+  RootedObject promise(cx, JS::NewPromiseObject(cx, nullptr));
+  if (!promise) {
+    return nullptr;
+  }
+  if (!JS::ResolvePromise(cx, promise, value)) {
+    return nullptr;
+  }
+  return promise;
+}
+
+static JSObject* KandeloRejectedPromise(JSContext* cx, const char* message) {
+  RootedObject promise(cx, JS::NewPromiseObject(cx, nullptr));
+  if (!promise) {
+    return nullptr;
+  }
+  RootedValue reason(cx);
+  JS_ReportErrorASCII(cx, "%s", message ? message : "native promise rejected");
+  if (!JS_GetPendingException(cx, &reason)) {
+    JS_ClearPendingException(cx);
+    RootedString str(cx, JS_NewStringCopyZ(cx, message ? message : "error"));
+    if (!str) {
+      return nullptr;
+    }
+    reason.setString(str);
+  }
+  JS_ClearPendingException(cx);
+  if (!JS::RejectPromise(cx, promise, reason)) {
+    return nullptr;
+  }
+  return promise;
+}
