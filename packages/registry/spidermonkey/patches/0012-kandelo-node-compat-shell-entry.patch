+static bool os_fstat(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  if (args.length() != 1) {
+    JS_ReportErrorNumberASCII(cx, my_GetErrorMessage, nullptr,
+                              JSSMSG_INVALID_ARGS, "fstat");
+    return false;
+  }
+
+  int32_t fd;
+  if (!JS::ToInt32(cx, args[0], &fd)) {
+    return false;
+  }
+  struct stat st;
+  int rc = fstat(fd, &st);
+  return StatArray(cx, st, rc == 0 ? 0 : errno, args.rval());
