+static bool KandeloZlibOneShot(JSContext* cx, const CallArgs& args,
+                               bool deflateMode, int windowBits, int level) {
+  if (args.length() < 1) {
+    JS_ReportErrorASCII(cx, "zlib input required");
+    return false;
+  }
+  std::vector<uint8_t> input;
+  if (!KandeloValueToBytes(cx, args[0], &input)) {
+    return false;
+  }
+  RootedValue streamValue(cx);
+  if (!KandeloMakeZlib(cx, deflateMode, windowBits, level, &streamValue)) {
+    return false;
+  }
+  RootedObject streamObj(cx, &streamValue.toObject());
+  auto* state =
+      static_cast<KandeloZlibState*>(JS::GetReservedSlot(streamObj, 0).toPrivate());
+  return KandeloZlibRun(cx, state, input.data(), input.size(), true, args.rval());
+}
