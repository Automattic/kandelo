+static bool DefineStatNumber(JSContext* cx, HandleObject obj, const char* name,
+                             double number) {
+  RootedValue value(cx, NumberValue(number));
+  return JS_DefineProperty(cx, obj, name, value, JSPROP_ENUMERATE);
+}
+
+static bool StatPath(JSContext* cx, unsigned argc, Value* vp,
+                     const char* name, bool followSymlinks) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+
+  if (args.length() != 1 || !args[0].isString()) {
+    JS_ReportErrorNumberASCII(cx, my_GetErrorMessage, nullptr,
+                              JSSMSG_INVALID_ARGS, name);
+    return false;
+  }
+
+  RootedString givenPath(cx, args[0].toString());
+  RootedString str(cx, ResolvePath(cx, givenPath, RootRelative));
+  if (!str) {
+    return false;
+  }
+
+  UniqueChars filename = JS_EncodeStringToUTF8(cx, str);
+  if (!filename) {
+    return false;
+  }
+
+  struct stat st;
+#ifdef XP_WIN
+  int rc = stat(filename.get(), &st);
+#else
+  int rc = followSymlinks ? stat(filename.get(), &st) : lstat(filename.get(), &st);
+#endif
+  if (rc != 0) {
+    JS_ReportErrorUTF8(cx, "%s failed for %s: errno %d", name, filename.get(),
+                       errno);
+    return false;
+  }
+
+  RootedObject obj(cx, JS_NewPlainObject(cx));
+  if (!obj) {
+    return false;
+  }
+
+  if (!DefineStatNumber(cx, obj, "dev", double(st.st_dev)) ||
+      !DefineStatNumber(cx, obj, "ino", double(st.st_ino)) ||
+      !DefineStatNumber(cx, obj, "mode", double(st.st_mode)) ||
+      !DefineStatNumber(cx, obj, "nlink", double(st.st_nlink)) ||
+      !DefineStatNumber(cx, obj, "uid", double(st.st_uid)) ||
+      !DefineStatNumber(cx, obj, "gid", double(st.st_gid)) ||
+      !DefineStatNumber(cx, obj, "rdev", double(st.st_rdev)) ||
+      !DefineStatNumber(cx, obj, "size", double(st.st_size)) ||
+      !DefineStatNumber(cx, obj, "atime", double(st.st_atime)) ||
+      !DefineStatNumber(cx, obj, "mtime", double(st.st_mtime)) ||
+      !DefineStatNumber(cx, obj, "ctime", double(st.st_ctime))) {
+    return false;
+  }
+
+  args.rval().setObject(*obj);
+  return true;
+}
+
+static bool osfile_stat(JSContext* cx, unsigned argc, Value* vp) {
+  return StatPath(cx, argc, vp, "stat", true);
+}
+
+static bool osfile_lstat(JSContext* cx, unsigned argc, Value* vp) {
+  return StatPath(cx, argc, vp, "lstat", false);
+}
