+static int KandeloResolveHost(const char* host, struct in_addr* out) {
+  if (inet_aton(host, out)) return 0;
+  struct addrinfo hints = {};
+  hints.ai_family = AF_INET;
+  hints.ai_socktype = SOCK_STREAM;
+  struct addrinfo* res = nullptr;
+  int rc = getaddrinfo(host, nullptr, &hints, &res);
+  if (rc != 0 || !res) return -1;
+  *out = reinterpret_cast<struct sockaddr_in*>(res->ai_addr)->sin_addr;
+  freeaddrinfo(res);
+  return 0;
+}
+
+enum class KandeloSocketWatchKind {
+  Connect,
+  Read,
+  Write,
+};
+
+struct KandeloSocketWatch {
+  int fd = -1;
+  KandeloSocketWatchKind kind;
+  JSContext* cx = nullptr;
+  PersistentRootedObject promise;
+  std::vector<uint8_t> buffer;
+  size_t offset = 0;
+  KandeloSocketWatch* next = nullptr;
+
+  KandeloSocketWatch(JSContext* cx, int fd, KandeloSocketWatchKind kind,
+                     HandleObject promise)
+      : fd(fd), kind(kind), cx(cx), promise(cx, promise) {}
+};
+
+static KandeloSocketWatch* gKandeloSocketWatches = nullptr;
+
+static int KandeloSetNonblocking(int fd) {
+  int flags = fcntl(fd, F_GETFL, 0);
+  if (flags < 0) return -1;
+  return fcntl(fd, F_SETFL, flags | O_NONBLOCK);
+}
+
+static void KandeloSocketWatchLink(KandeloSocketWatch* watch) {
+  watch->next = gKandeloSocketWatches;
+  gKandeloSocketWatches = watch;
+}
+
+static void KandeloSocketWatchUnlink(KandeloSocketWatch* target) {
+  KandeloSocketWatch** current = &gKandeloSocketWatches;
+  while (*current) {
+    if (*current == target) {
+      *current = target->next;
+      target->next = nullptr;
+      return;
+    }
+    current = &(*current)->next;
+  }
+}
+
+static bool KandeloSocketHasWatches() { return gKandeloSocketWatches != nullptr; }
+
+static bool KandeloResolvePromiseWithErrno(JSContext* cx, HandleObject promise,
+                                           int err, const char* fallback) {
+  const char* message = err ? strerror(err) : fallback;
+  RootedString str(cx, JS_NewStringCopyZ(cx, message ? message : "socket error"));
+  if (!str) return false;
+  RootedValue reason(cx, StringValue(str));
+  return JS::RejectPromise(cx, promise, reason);
+}
+
+static bool KandeloResolvePromiseWithInt(JSContext* cx, HandleObject promise,
+                                         int32_t value) {
+  RootedValue resolved(cx, Int32Value(value));
+  return JS::ResolvePromise(cx, promise, resolved);
+}
+
+static bool KandeloResolvePromiseWithBytes(JSContext* cx, HandleObject promise,
+                                           const uint8_t* bytes, size_t length) {
+  RootedObject array(cx, KandeloNewUint8ArrayCopy(cx, bytes, length));
+  if (!array) return false;
+  RootedValue resolved(cx, ObjectValue(*array));
+  return JS::ResolvePromise(cx, promise, resolved);
+}
+
+static int KandeloSocketDispatch(JSContext* cx) {
+  int count = 0;
+  for (KandeloSocketWatch* watch = gKandeloSocketWatches; watch;
+       watch = watch->next) {
+    count++;
+  }
+  if (count == 0) return 0;
+
+  std::vector<pollfd> pollfds;
+  pollfds.reserve(size_t(count));
+  for (KandeloSocketWatch* watch = gKandeloSocketWatches; watch;
+       watch = watch->next) {
+    pollfd pfd = {};
+    pfd.fd = watch->fd;
+    pfd.events = watch->kind == KandeloSocketWatchKind::Read ? POLLIN : POLLOUT;
+    pollfds.push_back(pfd);
+  }
+
+  int rc = poll(pollfds.data(), nfds_t(pollfds.size()), 0);
+  if (rc <= 0) return 0;
+
+  int processed = 0;
+  KandeloSocketWatch* watch = gKandeloSocketWatches;
+  size_t index = 0;
+  while (watch && index < pollfds.size()) {
+    KandeloSocketWatch* next = watch->next;
+    short revents = pollfds[index++].revents;
+    if (revents == 0) {
+      watch = next;
+      continue;
+    }
+
+    bool done = false;
+    if (watch->kind == KandeloSocketWatchKind::Connect) {
+      int err = 0;
+      socklen_t len = sizeof(err);
+      if (getsockopt(watch->fd, SOL_SOCKET, SO_ERROR, &err, &len) == 0 &&
+          err == 0) {
+        KandeloResolvePromiseWithInt(cx, watch->promise, watch->fd);
+      } else {
+        KandeloResolvePromiseWithErrno(cx, watch->promise,
+                                       err ? err : ECONNREFUSED, nullptr);
+      }
+      done = true;
+    } else if (watch->kind == KandeloSocketWatchKind::Read) {
+      ssize_t n = read(watch->fd, watch->buffer.data(), watch->buffer.size());
+      if (n >= 0) {
+        KandeloResolvePromiseWithBytes(cx, watch->promise, watch->buffer.data(),
+                                       size_t(n));
+        done = true;
+      } else if (errno != EAGAIN && errno != EWOULDBLOCK) {
+        KandeloResolvePromiseWithErrno(cx, watch->promise, errno, nullptr);
+        done = true;
+      }
+    } else {
+      ssize_t n = write(watch->fd, watch->buffer.data() + watch->offset,
+                        watch->buffer.size() - watch->offset);
+      if (n > 0) {
+        watch->offset += size_t(n);
+        if (watch->offset >= watch->buffer.size()) {
+          KandeloResolvePromiseWithInt(cx, watch->promise,
+                                       int32_t(watch->buffer.size()));
+          done = true;
+        }
+      } else if (n < 0 && errno != EAGAIN && errno != EWOULDBLOCK) {
+        KandeloResolvePromiseWithErrno(cx, watch->promise, errno, nullptr);
+        done = true;
+      }
+    }
+
+    if (done) {
+      KandeloSocketWatchUnlink(watch);
+      js_delete(watch);
+      processed++;
+    }
+    watch = next;
+  }
+
+  return processed;
+}
+
+static bool KandeloNativeSocketConnect(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  UniqueChars host;
+  if (args.length() < 2 || !KandeloGetString(cx, args[0], &host)) {
+    return false;
+  }
+  int32_t port;
+  if (!JS::ToInt32(cx, args[1], &port)) {
+    return false;
+  }
+  RootedObject promise(cx, JS::NewPromiseObject(cx, nullptr));
+  if (!promise) return false;
+  args.rval().setObject(*promise);
+
+  struct in_addr addr;
+  if (port < 0 || port > 65535 || KandeloResolveHost(host.get(), &addr) != 0) {
+    return KandeloResolvePromiseWithErrno(cx, promise, 0, "ENOTFOUND");
+  }
+  int fd = socket(AF_INET, SOCK_STREAM, 0);
+  if (fd < 0) {
+    return KandeloResolvePromiseWithErrno(cx, promise, errno, nullptr);
+  }
+  KandeloSetNonblocking(fd);
+  struct sockaddr_in sa = {};
+  sa.sin_family = AF_INET;
+  sa.sin_port = htons(uint16_t(port));
+  sa.sin_addr = addr;
+  int rc = connect(fd, reinterpret_cast<struct sockaddr*>(&sa), sizeof(sa));
+  if (rc == 0) {
+    return KandeloResolvePromiseWithInt(cx, promise, fd);
+  }
+  if (errno != EINPROGRESS && errno != EAGAIN && errno != EALREADY) {
+    int err = errno;
+    close(fd);
+    return KandeloResolvePromiseWithErrno(cx, promise, err, nullptr);
+  }
+
+  auto* watch =
+      js_new<KandeloSocketWatch>(cx, fd, KandeloSocketWatchKind::Connect,
+                                 promise);
+  if (!watch) {
+    close(fd);
+    JS_ReportOutOfMemory(cx);
+    return false;
+  }
+  KandeloSocketWatchLink(watch);
+  return true;
+}
+
+static bool KandeloNativeSocketRead(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  int32_t fd;
+  int32_t length = 16384;
+  if (args.length() < 1 || !JS::ToInt32(cx, args[0], &fd)) return false;
+  if (args.length() >= 2 && !JS::ToInt32(cx, args[1], &length)) return false;
+  if (length <= 0) length = 16384;
+  RootedObject promise(cx, JS::NewPromiseObject(cx, nullptr));
+  if (!promise) return false;
+  args.rval().setObject(*promise);
+
+  std::vector<uint8_t> buffer(static_cast<size_t>(length));
+  ssize_t n = read(fd, buffer.data(), buffer.size());
+  if (n >= 0) {
+    return KandeloResolvePromiseWithBytes(cx, promise, buffer.data(), size_t(n));
+  }
+  if (errno != EAGAIN && errno != EWOULDBLOCK) {
+    return KandeloResolvePromiseWithErrno(cx, promise, errno, nullptr);
+  }
+
+  auto* watch = js_new<KandeloSocketWatch>(cx, fd, KandeloSocketWatchKind::Read,
+                                           promise);
+  if (!watch) {
+    JS_ReportOutOfMemory(cx);
+    return false;
+  }
+  watch->buffer = std::move(buffer);
+  KandeloSocketWatchLink(watch);
+  return true;
+}
+
+static bool KandeloNativeSocketWrite(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  int32_t fd;
+  if (args.length() < 2 || !JS::ToInt32(cx, args[0], &fd)) return false;
+  std::vector<uint8_t> bytes;
+  if (!KandeloValueToBytes(cx, args[1], &bytes)) return false;
+  RootedObject promise(cx, JS::NewPromiseObject(cx, nullptr));
+  if (!promise) return false;
+  args.rval().setObject(*promise);
+  if (bytes.empty()) {
+    return KandeloResolvePromiseWithInt(cx, promise, 0);
+  }
+
+  ssize_t n = write(fd, bytes.data(), bytes.size());
+  if (n >= 0 && size_t(n) == bytes.size()) {
+    return KandeloResolvePromiseWithInt(cx, promise, int32_t(n));
+  }
+  if (n < 0 && errno != EAGAIN && errno != EWOULDBLOCK) {
+    return KandeloResolvePromiseWithErrno(cx, promise, errno, nullptr);
+  }
+
+  auto* watch =
+      js_new<KandeloSocketWatch>(cx, fd, KandeloSocketWatchKind::Write,
+                                 promise);
+  if (!watch) {
+    JS_ReportOutOfMemory(cx);
+    return false;
+  }
+  watch->buffer = std::move(bytes);
+  watch->offset = n > 0 ? size_t(n) : 0;
+  KandeloSocketWatchLink(watch);
+  return true;
+}
+
+static bool KandeloNativeSocketClose(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  int32_t fd;
+  if (args.length() >= 1 && JS::ToInt32(cx, args[0], &fd) && fd >= 0) {
+    KandeloSocketWatch** current = &gKandeloSocketWatches;
+    while (*current) {
+      KandeloSocketWatch* watch = *current;
+      if (watch->fd == fd) {
+        *current = watch->next;
+        KandeloResolvePromiseWithErrno(cx, watch->promise, 0, "socket closed");
+        js_delete(watch);
+      } else {
+        current = &watch->next;
+      }
+    }
+    close(fd);
+  }
+  args.rval().setUndefined();
+  return true;
+}
+
+struct KandeloTlsHandle {
+  bool active = false;
+  int fd = -1;
+  SSL* ssl = nullptr;
+  SSL_CTX* ctx = nullptr;
+};
+
+static constexpr int KandeloMaxTlsHandles = 1024;
+static KandeloTlsHandle gKandeloTlsHandles[KandeloMaxTlsHandles];
+
+static int KandeloAllocTlsHandle(int fd, SSL* ssl, SSL_CTX* ctx) {
+  for (int i = 0; i < KandeloMaxTlsHandles; i++) {
+    if (!gKandeloTlsHandles[i].active) {
+      gKandeloTlsHandles[i].active = true;
+      gKandeloTlsHandles[i].fd = fd;
+      gKandeloTlsHandles[i].ssl = ssl;
+      gKandeloTlsHandles[i].ctx = ctx;
+      return i + 1;
+    }
+  }
+  return -1;
+}
+
+static KandeloTlsHandle* KandeloGetTlsHandle(int handle) {
+  if (handle < 1 || handle > KandeloMaxTlsHandles) return nullptr;
+  auto* h = &gKandeloTlsHandles[handle - 1];
+  return h->active ? h : nullptr;
+}
+
+static void KandeloCloseTlsHandle(int handle) {
+  KandeloTlsHandle* h = KandeloGetTlsHandle(handle);
+  if (!h) return;
+  if (h->ssl) {
+    SSL_shutdown(h->ssl);
+    SSL_free(h->ssl);
+  }
+  if (h->ctx) SSL_CTX_free(h->ctx);
+  if (h->fd >= 0) close(h->fd);
+  *h = KandeloTlsHandle();
+}
+
+static SSL_CTX* KandeloMakeTlsContext(JSContext* cx, HandleValue optionsValue) {
+  SSL_CTX* ctx = SSL_CTX_new(TLS_client_method());
+  if (!ctx) return nullptr;
+  SSL_CTX_set_min_proto_version(ctx, TLS1_2_VERSION);
+  bool rejectUnauthorized = true;
+  RootedValue caValue(cx);
+  if (optionsValue.isObject()) {
+    RootedObject opts(cx, &optionsValue.toObject());
+    RootedValue rejectValue(cx);
+    if (JS_GetProperty(cx, opts, "rejectUnauthorized", &rejectValue) &&
+        rejectValue.isBoolean()) {
+      rejectUnauthorized = rejectValue.toBoolean();
+    }
+    JS_GetProperty(cx, opts, "ca", &caValue);
+  }
+  if (!caValue.isUndefined() && !caValue.isNull()) {
+    UniqueChars ca;
+    if (!KandeloGetString(cx, caValue, &ca)) {
+      SSL_CTX_free(ctx);
+      return nullptr;
+    }
+    BIO* bio = BIO_new_mem_buf(ca.get(), -1);
+    if (!bio) {
+      SSL_CTX_free(ctx);
+      return nullptr;
+    }
+    X509_STORE* store = SSL_CTX_get_cert_store(ctx);
+    X509* cert = nullptr;
+    int count = 0;
+    while ((cert = PEM_read_bio_X509(bio, nullptr, nullptr, nullptr))) {
+      if (X509_STORE_add_cert(store, cert)) count++;
+      X509_free(cert);
+    }
+    BIO_free(bio);
+    ERR_clear_error();
+    if (count == 0) {
+      SSL_CTX_free(ctx);
+      return nullptr;
+    }
+  } else {
+    SSL_CTX_set_default_verify_paths(ctx);
+  }
+  SSL_CTX_set_verify(ctx, rejectUnauthorized ? SSL_VERIFY_PEER : SSL_VERIFY_NONE,
+                     nullptr);
+  return ctx;
+}
+
+static bool KandeloNativeTlsConnect(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  int32_t fd;
+  if (args.length() < 2 || !JS::ToInt32(cx, args[0], &fd)) return false;
+  UniqueChars servername;
+  if (!KandeloGetString(cx, args[1], &servername)) return false;
+  RootedValue options(cx, args.length() >= 3 ? args[2] : UndefinedValue());
+  SSL_CTX* ctx = KandeloMakeTlsContext(cx, options);
+  if (!ctx) {
+    RootedObject promise(cx, KandeloRejectedPromise(cx, "TLS context failed"));
+    if (!promise) return false;
+    args.rval().setObject(*promise);
+    return true;
+  }
+  SSL* ssl = SSL_new(ctx);
+  if (!ssl) {
+    SSL_CTX_free(ctx);
+    RootedObject promise(cx, KandeloRejectedPromise(cx, "SSL_new failed"));
+    if (!promise) return false;
+    args.rval().setObject(*promise);
+    return true;
+  }
+  SSL_set_fd(ssl, fd);
+  SSL_set_tlsext_host_name(ssl, servername.get());
+  SSL_set1_host(ssl, servername.get());
+  if (SSL_connect(ssl) != 1) {
+    SSL_free(ssl);
+    SSL_CTX_free(ctx);
+    RootedObject promise(cx, KandeloRejectedPromise(cx, "TLS handshake failed"));
+    if (!promise) return false;
+    args.rval().setObject(*promise);
+    return true;
+  }
+  int handle = KandeloAllocTlsHandle(fd, ssl, ctx);
+  if (handle < 0) {
+    SSL_free(ssl);
+    SSL_CTX_free(ctx);
+    RootedObject promise(cx, KandeloRejectedPromise(cx, "TLS handle table full"));
+    if (!promise) return false;
+    args.rval().setObject(*promise);
+    return true;
+  }
+  RootedValue value(cx, Int32Value(handle));
+  RootedObject promise(cx, KandeloResolvedPromise(cx, value));
+  if (!promise) return false;
+  args.rval().setObject(*promise);
+  return true;
+}
+
+static bool KandeloNativeTlsRead(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  int32_t handle;
+  int32_t length = 16384;
+  if (args.length() < 1 || !JS::ToInt32(cx, args[0], &handle)) return false;
+  if (args.length() >= 2 && !JS::ToInt32(cx, args[1], &length)) return false;
+  if (length <= 0) length = 16384;
+  KandeloTlsHandle* h = KandeloGetTlsHandle(handle);
+  if (!h) return false;
+  std::vector<uint8_t> buffer(static_cast<size_t>(length));
+  int n = SSL_read(h->ssl, buffer.data(), int(buffer.size()));
+  if (n < 0) {
+    RootedObject promise(cx, KandeloRejectedPromise(cx, "TLS read failed"));
+    if (!promise) return false;
+    args.rval().setObject(*promise);
+    return true;
+  }
+  RootedObject bytes(cx, KandeloNewUint8ArrayCopy(cx, buffer.data(), size_t(n)));
+  if (!bytes) return false;
+  RootedValue value(cx, ObjectValue(*bytes));
+  RootedObject promise(cx, KandeloResolvedPromise(cx, value));
+  if (!promise) return false;
+  args.rval().setObject(*promise);
+  return true;
+}
+
+static bool KandeloNativeTlsWrite(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  int32_t handle;
+  if (args.length() < 2 || !JS::ToInt32(cx, args[0], &handle)) return false;
+  KandeloTlsHandle* h = KandeloGetTlsHandle(handle);
+  if (!h) return false;
+  std::vector<uint8_t> bytes;
+  if (!KandeloValueToBytes(cx, args[1], &bytes)) return false;
+  size_t written = 0;
+  while (written < bytes.size()) {
+    int n = SSL_write(h->ssl, bytes.data() + written, int(bytes.size() - written));
+    if (n <= 0) {
+      RootedObject promise(cx, KandeloRejectedPromise(cx, "TLS write failed"));
+      if (!promise) return false;
+      args.rval().setObject(*promise);
+      return true;
+    }
+    written += size_t(n);
+  }
+  RootedValue value(cx, Int32Value(int32_t(written)));
+  RootedObject promise(cx, KandeloResolvedPromise(cx, value));
+  if (!promise) return false;
+  args.rval().setObject(*promise);
+  return true;
+}
+
+static bool KandeloNativeTlsClose(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  int32_t handle;
+  if (args.length() >= 1 && JS::ToInt32(cx, args[0], &handle)) {
+    KandeloCloseTlsHandle(handle);
+  }
+  args.rval().setUndefined();
+  return true;
+}
+
+static bool KandeloNativeEvalScriptAsFunction(JSContext* cx, unsigned argc,
+                                              Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  if (args.length() < 2) {
+    JS_ReportErrorASCII(cx, "evalScriptAsFunction(source, filename)");
+    return false;
+  }
+  UniqueChars source;
+  UniqueChars filename;
+  if (!KandeloGetString(cx, args[0], &source) ||
+      !KandeloGetString(cx, args[1], &filename)) {
+    return false;
+  }
+  JS::CompileOptions opts(cx);
+  opts.setFileAndLine(filename.get(), 1).setForceFullParse();
+  JS::SourceText<Utf8Unit> srcBuf;
+  if (!srcBuf.init(cx, reinterpret_cast<const Utf8Unit*>(source.get()),
+                   strlen(source.get()), JS::SourceOwnership::Borrowed)) {
+    return false;
+  }
+  RootedValue rval(cx);
+  if (!JS::Evaluate(cx, opts, srcBuf, &rval)) {
+    return false;
+  }
+  args.rval().set(rval);
+  return true;
+}
+
+static bool DefineKandeloNodeNative(JSContext* cx) {
+  RootedObject native(cx, JS_NewPlainObject(cx));
+  if (!native) {
+    return false;
