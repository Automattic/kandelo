+static bool os_read(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  if (args.length() != 4) {
+    JS_ReportErrorNumberASCII(cx, my_GetErrorMessage, nullptr,
+                              JSSMSG_INVALID_ARGS, "read");
+    return false;
+  }
+
+  int32_t fd;
+  int32_t offset;
+  int32_t length;
+  if (!JS::ToInt32(cx, args[0], &fd) || !JS::ToInt32(cx, args[2], &offset) ||
+      !JS::ToInt32(cx, args[3], &length)) {
+    return false;
+  }
+
+  uint8_t* data = nullptr;
+  size_t dataLen = 0;
+  if (!GetArrayBufferBytes(cx, args[1], &data, &dataLen)) {
+    return false;
+  }
+  if (offset < 0 || length < 0 || size_t(offset) > dataLen ||
+      size_t(length) > dataLen - size_t(offset)) {
+    JS_ReportErrorASCII(cx, "read offset/length out of range");
+    return false;
+  }
+
+  ssize_t n = read(fd, data + offset, size_t(length));
+  args.rval().setInt32(n >= 0 ? int32_t(n) : -errno);
+  return true;
+}
