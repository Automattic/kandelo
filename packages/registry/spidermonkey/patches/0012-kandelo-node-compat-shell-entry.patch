+static bool GetArrayBufferBytes(JSContext* cx, HandleValue value,
+                                uint8_t** dataOut, size_t* lengthOut) {
+  if (!value.isObject()) {
+    JS_ReportErrorASCII(cx, "expected ArrayBuffer");
+    return false;
+  }
+  RootedObject obj(cx, &value.toObject());
+  if (!JS::IsArrayBufferObject(obj)) {
+    JS_ReportErrorASCII(cx, "expected ArrayBuffer");
+    return false;
+  }
+  bool isShared = false;
+  JS::AutoCheckCannotGC nogc;
+  *dataOut = JS::GetArrayBufferData(obj, &isShared, nogc);
+  *lengthOut = JS::GetArrayBufferByteLength(obj);
+  if (isShared) {
+    JS_ReportErrorASCII(cx, "shared ArrayBuffer is not supported here");
+    return false;
+  }
+  return true;
+}
