+static bool osfile_utimes(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+
+  if (args.length() != 3 || !args[0].isString()) {
+    JS_ReportErrorNumberASCII(cx, my_GetErrorMessage, nullptr,
+                              JSSMSG_INVALID_ARGS, "utimes");
+    return false;
+  }
+
+  double atime;
+  double mtime;
+  if (!JS::ToNumber(cx, args[1], &atime) || !JS::ToNumber(cx, args[2], &mtime)) {
+    return false;
+  }
+
+  RootedString givenPath(cx, args[0].toString());
+  RootedString str(cx, ResolvePath(cx, givenPath, RootRelative));
+  UniqueChars filename = str ? JS_EncodeStringToUTF8(cx, str) : nullptr;
+  if (!filename) {
+    return false;
+  }
+
+#if defined(XP_WIN)
+  args.rval().setInt32(-ENOSYS);
+#else
+  struct timespec times[2];
+  times[0].tv_sec = time_t(atime);
+  times[0].tv_nsec = long((atime - double(times[0].tv_sec)) * 1000000000.0);
+  times[1].tv_sec = time_t(mtime);
+  times[1].tv_nsec = long((mtime - double(times[1].tv_sec)) * 1000000000.0);
+  int rc = utimensat(AT_FDCWD, filename.get(), times, 0);
+  args.rval().setInt32(rc == 0 ? 0 : -errno);
+#endif
+  return true;
+}
