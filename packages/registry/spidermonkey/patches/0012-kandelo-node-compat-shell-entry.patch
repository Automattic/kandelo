+    JS_ReportErrorNumberASCII(cx, my_GetErrorMessage, nullptr,
+                              JSSMSG_INVALID_ARGS, "mkdir");
+    return false;
+  }
+
+  int32_t mode = 0777;
+  if (args.length() == 2 && !JS::ToInt32(cx, args[1], &mode)) {
+    return false;
