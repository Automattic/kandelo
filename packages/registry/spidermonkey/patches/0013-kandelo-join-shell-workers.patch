+static void RequestShellWorkerTermination(UniqueLock<Mutex>& lock,
+                                          WorkerThreadControl* control) {
+  if (!control) {
+    return;
+  }
+
+  while (!control->finished && !control->cx) {
+    control->ready.wait(lock);
+  }
+
+  if (control->finished || !control->cx) {
+    return;
+  }
+
+  ShellContext* sc = GetShellContext(control->cx);
+  sc->serviceInterrupt = true;
+  js::StopDrainingJobQueue(control->cx);
+  JS_RequestInterruptCallback(control->cx);
+}
