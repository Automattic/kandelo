+	zend_ast **chain_right = NULL;
+	uint32_t chain_n = 0, chain_cap = 0;
+	zend_ast *cur = ast;
+	while (cur->kind == ZEND_AST_BINARY_OP && cur->attr == opcode) {
+		if (chain_n == chain_cap) {
+			chain_cap = chain_cap ? chain_cap * 2 : 8;
+			chain_right = erealloc(chain_right, chain_cap * sizeof(zend_ast *));
+		}
+		chain_right[chain_n++] = cur->child[1];
+		cur = cur->child[0];
+	}
+
+	znode left_node;
+	zend_compile_expr(&left_node, cur);
