@@ -0,0 +1,20 @@
+--TEST--
+Stack limit 014 - Deep || chain compiles iteratively without overflowing
+--SKIPIF--
+<?php
+if (!function_exists('zend_test_zend_call_stack_get')) die("skip zend_test_zend_call_stack_get() is not available");
+?>
+--EXTENSIONS--
+zend_test
+--INI--
+zend.max_allowed_stack_size=64K
+--FILE--
+<?php
+$a = $b = $c = false;
+$d = true;
+$src = '$result = $a' . str_repeat(' || $b || $c', 500) . ' || $d;';
+eval($src);
+var_dump($result);
+?>
+--EXPECT--
+bool(true)
