QuickJS's qjs:os module exposes os.exec via a direct fork()/exec()
implementation. The Node-compatible runtime does not use that API for npm:
its child_process shim calls std.popen(), and musl's wasm32posix popen()
uses the non-forking posix_spawn syscall.

Keep qjs.wasm's os.exec behavior unchanged, but let node.wasm omit the
fork-only qjs:os.exec export. That keeps Node's normal npm startup out of the
fork-instrumented QuickJS interpreter path while preserving fork
instrumentation for the standalone qjs binary that still exposes os.exec.

diff --git a/quickjs-libc.c b/quickjs-libc.c
--- a/quickjs-libc.c
+++ b/quickjs-libc.c
@@ -4382,7 +4382,9 @@ static const JSCFunctionListEntry js_os_funcs[] = {
 #if !defined(_WIN32) && !defined(__wasi__) && !(defined(__APPLE__) && (TARGET_OS_TV || TARGET_OS_WATCH))
     JS_CFUNC_MAGIC_DEF("lstat", 1, js_os_stat, 1 ),
     JS_CFUNC_DEF("symlink", 2, js_os_symlink ),
     JS_CFUNC_DEF("readlink", 1, js_os_readlink ),
+#if !defined(WASM_POSIX_NODE_NO_OS_EXEC)
     JS_CFUNC_DEF("exec", 1, js_os_exec ),
+#endif
     JS_CFUNC_DEF("getpid", 0, js_os_getpid ),
     JS_CFUNC_DEF("waitpid", 2, js_os_waitpid ),
     OS_FLAG(WNOHANG),
