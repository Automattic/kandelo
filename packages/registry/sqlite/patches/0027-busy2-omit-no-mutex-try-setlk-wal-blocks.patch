+set ::busy2_no_mutex_try_setlk_reason "Kandelo builds SQLite with ENABLE_SETLK_TIMEOUT; no_mutex_try forces sqlite3_mutex_try() to fail, but ENABLE_SETLK_TIMEOUT WAL shared-memory exclusive locks intentionally use sqlite3_mutex_try() to avoid deadlocks"
+proc busy2_omit_no_mutex_try_setlk {cases} {
+  foreach case $cases {
+    omit_test busy2-$case $::busy2_no_mutex_try_setlk_reason
+  }
