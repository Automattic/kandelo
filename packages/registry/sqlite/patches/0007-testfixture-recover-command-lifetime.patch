       }
       res2 = sqlite3_recover_finish(pTest->p);
+      pTest->p = 0;
       assert( res2==res );
+      Tcl_DeleteCommandFromToken(interp, pTest->cmd);
       if( res ) return TCL_ERROR;
       break;
     }
