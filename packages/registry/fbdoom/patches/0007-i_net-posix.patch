diff --git a/fbdoom/net_posix.c b/fbdoom/net_posix.c
new file mode 100644
index 0000000..19480ba
--- /dev/null
+++ b/fbdoom/net_posix.c
@@ -0,0 +1,419 @@
+//
+// Copyright(C) 2005-2014 Simon Howard (chocolate-doom net_sdl.c — basis)
+// Copyright(C) 2026 wasm-posix-kernel contributors (POSIX adaptation)
+//
+// This program is free software; you can redistribute it and/or
+// modify it under the terms of the GNU General Public License
+// as published by the Free Software Foundation; either version 2
+// of the License, or (at your option) any later version.
+//
+// This program is distributed in the hope that it will be useful,
+// but WITHOUT ANY WARRANTY; without even the implied warranty of
+// MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+// GNU General Public License for more details.
+//
+// DESCRIPTION:
+//     POSIX BSD-sockets transport for chocolate-doom's net_module_t.
+//     A drop-in replacement for net_sdl.c in environments that don't
+//     ship SDL_net. Structure deliberately mirrors net_sdl.c so a
+//     reader who already knows that file can map function-by-function.
+//
+//     Wasm-posix-kernel context: socket(AF_INET, SOCK_DGRAM, 0) routes
+//     through the kernel's HostIO::send_dgram trait (and the inbound
+//     side through kernel_inject_datagram). The browser host fans
+//     those out over a WebRTC RTCDataChannel via the RelayChannel /
+//     RelayHostShim pair — see the multiplayer-doom-webrtc design doc
+//     §5 and the host-side wiring at host/src/browser-kernel-worker-
+//     entry.ts (RelayHostShim, handleInjectDatagram).
+//
+//     Also provides a textscreen-free NET_WaitForLaunch replacement.
+//     chocolate-doom's net_gui.c draws a "waiting for launch" UI via
+//     TXT_*; fbDOOM doesn't link textscreen, so we spin on the net
+//     state until the server flips net_waiting_for_launch off. The
+//     browser-side page surfaces user-visible "waiting for player N..."
+//     status via its own RTT probe (design §7).
+//
+
+#include <stdlib.h>
+#include <string.h>
+#include <stdio.h>
+#include <errno.h>
+#include <unistd.h>
+#include <fcntl.h>
+
+#include <sys/socket.h>
+#include <netinet/in.h>
+#include <arpa/inet.h>
+
+#include "doomtype.h"
+#include "i_system.h"
+#include "i_timer.h"
+#include "m_argv.h"
+#include "m_misc.h"
+#include "net_defs.h"
+#include "net_io.h"
+#include "net_packet.h"
+#include "net_client.h"
+#include "net_server.h"
+#include "z_zone.h"
+
+// Default UDP port. Matches the synthetic /24 used by the
+// browser-side RelayChannel (10.99.0.0/24:5029). See design §3.
+#define DEFAULT_PORT 5029
+
+typedef struct
+{
+    net_addr_t        net_addr;
+    struct sockaddr_in sin;
+} addrpair_t;
+
+static boolean      initted        = false;
+static int          port           = DEFAULT_PORT;
+static int          udpsock        = -1;
+static addrpair_t **addr_table     = NULL;
+static int          addr_table_size = -1;
+
+net_module_t net_posix_module;
+
+// ---------------------------------------------------------------------
+// Address bookkeeping (1:1 with net_sdl.c's NET_SDL_FindAddress).
+// ---------------------------------------------------------------------
+
+static void InitAddrTable(void)
+{
+    addr_table_size = 16;
+    addr_table = Z_Malloc(sizeof(addrpair_t *) * addr_table_size,
+                          PU_STATIC, 0);
+    memset(addr_table, 0, sizeof(addrpair_t *) * addr_table_size);
+}
+
+static boolean AddressesEqual(const struct sockaddr_in *a,
+                              const struct sockaddr_in *b)
+{
+    return a->sin_addr.s_addr == b->sin_addr.s_addr
+        && a->sin_port        == b->sin_port;
+}
+
+static net_addr_t *FindAddress(const struct sockaddr_in *addr)
+{
+    addrpair_t *new_entry;
+    int empty_entry = -1;
+    int i;
+
+    if (addr_table_size < 0)
+    {
+        InitAddrTable();
+    }
+
+    for (i = 0; i < addr_table_size; ++i)
+    {
+        if (addr_table[i] != NULL
+         && AddressesEqual(addr, &addr_table[i]->sin))
+        {
+            return &addr_table[i]->net_addr;
+        }
+
+        if (empty_entry < 0 && addr_table[i] == NULL)
+            empty_entry = i;
+    }
+
+    // No slot free — double the table, copy in, swap.
+    if (empty_entry < 0)
+    {
+        addrpair_t **new_table;
+        int new_size;
+
+        empty_entry = addr_table_size;
+        new_size    = addr_table_size * 2;
+
+        new_table = Z_Malloc(sizeof(addrpair_t *) * new_size,
+                             PU_STATIC, 0);
+        memset(new_table, 0, sizeof(addrpair_t *) * new_size);
+        memcpy(new_table, addr_table,
+               sizeof(addrpair_t *) * addr_table_size);
+        Z_Free(addr_table);
+        addr_table      = new_table;
+        addr_table_size = new_size;
+    }
+
+    new_entry = Z_Malloc(sizeof(addrpair_t), PU_STATIC, 0);
+    new_entry->sin              = *addr;
+    new_entry->net_addr.refcount = 0;
+    new_entry->net_addr.handle  = &new_entry->sin;
+    new_entry->net_addr.module  = &net_posix_module;
+
+    addr_table[empty_entry] = new_entry;
+    return &new_entry->net_addr;
+}
+
+static void NET_POSIX_FreeAddress(net_addr_t *addr)
+{
+    int i;
+
+    for (i = 0; i < addr_table_size; ++i)
+    {
+        if (addr_table[i] != NULL && addr == &addr_table[i]->net_addr)
+        {
+            Z_Free(addr_table[i]);
+            addr_table[i] = NULL;
+            return;
+        }
+    }
+
+    I_Error("NET_POSIX_FreeAddress: Attempted to remove an unused address!");
+}
+
+// ---------------------------------------------------------------------
+// Socket open / bind.
+// ---------------------------------------------------------------------
+
+static boolean OpenSocket(int bind_port)
+{
+    struct sockaddr_in sa;
+    int flags;
+
+    udpsock = socket(AF_INET, SOCK_DGRAM, 0);
+    if (udpsock < 0) return false;
+
+    // Non-blocking is the contract net_io.c's per-tic poll expects from
+    // a module: RecvPacket must return false on an empty queue rather
+    // than block. The wasm-posix-kernel's sys_recvfrom returns EAGAIN
+    // unconditionally on empty (see crates/kernel/src/syscalls.rs
+    // around 6133-6134 — a documented follow-up), so the O_NONBLOCK
+    // flag here is belt-and-braces / portability with other hosts.
+    flags = fcntl(udpsock, F_GETFL, 0);
+    if (flags >= 0)
+    {
+        (void)fcntl(udpsock, F_SETFL, flags | O_NONBLOCK);
+    }
+
+    if (bind_port > 0)
+    {
+        memset(&sa, 0, sizeof(sa));
+        sa.sin_family      = AF_INET;
+        sa.sin_port        = htons((uint16_t)bind_port);
+        sa.sin_addr.s_addr = htonl(INADDR_ANY);
+        if (bind(udpsock, (struct sockaddr *)&sa, sizeof(sa)) < 0)
+        {
+            close(udpsock);
+            udpsock = -1;
+            return false;
+        }
+    }
+    return true;
+}
+
+// ---------------------------------------------------------------------
+// net_module_t entry points.
+// ---------------------------------------------------------------------
+
+static boolean NET_POSIX_InitClient(void)
+{
+    int p;
+
+    if (initted) return true;
+
+    //!
+    // @category net
+    // @arg <n>
+    //
+    // Use the specified UDP port for communications, instead of
+    // the default (5029).
+    //
+    p = M_CheckParmWithArgs("-port", 1);
+    if (p > 0) port = atoi(myargv[p + 1]);
+
+    // Client side binds to an ephemeral port; the kernel picks one.
+    if (!OpenSocket(0))
+    {
+        I_Error("NET_POSIX_InitClient: Unable to open socket: %s",
+                strerror(errno));
+    }
+
+    initted = true;
+    return true;
+}
+
+static boolean NET_POSIX_InitServer(void)
+{
+    int p;
+
+    if (initted) return true;
+
+    p = M_CheckParmWithArgs("-port", 1);
+    if (p > 0) port = atoi(myargv[p + 1]);
+
+    if (!OpenSocket(port))
+    {
+        I_Error("NET_POSIX_InitServer: Unable to bind to port %i: %s",
+                port, strerror(errno));
+    }
+
+    initted = true;
+    return true;
+}
+
+static void NET_POSIX_SendPacket(net_addr_t *addr, net_packet_t *packet)
+{
+    struct sockaddr_in sa;
+
+    if (udpsock < 0) return;
+
+    if (addr == &net_broadcast_addr)
+    {
+        memset(&sa, 0, sizeof(sa));
+        sa.sin_family      = AF_INET;
+        sa.sin_port        = htons((uint16_t)port);
+        sa.sin_addr.s_addr = htonl(INADDR_BROADCAST);
+    }
+    else
+    {
+        sa = *((struct sockaddr_in *)addr->handle);
+    }
+
+    // UDP is best-effort. The host's RelayChannel may be torn down
+    // (page navigation, peer disconnect); a transient sendto failure
+    // is indistinguishable from wire-level loss and must NOT escalate
+    // to I_Error here. chocolate-doom's net_sdl.c does call I_Error on
+    // failure; we relax that for the relay's looser delivery model.
+    (void)sendto(udpsock, packet->data, packet->len, 0,
+                 (struct sockaddr *)&sa, sizeof(sa));
+}
+
+static boolean NET_POSIX_RecvPacket(net_addr_t **addr, net_packet_t **packet)
+{
+    byte               buf[1500];
+    struct sockaddr_in sa;
+    socklen_t          slen = sizeof(sa);
+    ssize_t            n;
+
+    if (udpsock < 0) return false;
+
+    n = recvfrom(udpsock, buf, sizeof(buf), 0,
+                 (struct sockaddr *)&sa, &slen);
+
+    if (n < 0)
+    {
+        // EAGAIN / EWOULDBLOCK is the empty-queue case. Other errors
+        // (EINTR, …) we also treat as "no packet this tic" — the next
+        // poll will retry. Errors that mean "socket is dead" would
+        // legitimately surface as sustained zero-recv, which DOOM's
+        // higher-level netcode times out on (NET_CL_Run).
+        return false;
+    }
+    if (n == 0)
+        return false;
+
+    *packet = NET_NewPacket((int)n);
+    memcpy((*packet)->data, buf, (size_t)n);
+    (*packet)->len = (size_t)n;
+    *addr = FindAddress(&sa);
+    return true;
+}
+
+void NET_POSIX_AddrToString(net_addr_t *addr, char *buffer, int buffer_len)
+{
+    struct sockaddr_in *sa = (struct sockaddr_in *)addr->handle;
+    uint32_t            host = ntohl(sa->sin_addr.s_addr);
+    uint16_t            pt   = ntohs(sa->sin_port);
+
+    M_snprintf(buffer, buffer_len, "%u.%u.%u.%u",
+               (unsigned)((host >> 24) & 0xff),
+               (unsigned)((host >> 16) & 0xff),
+               (unsigned)((host >>  8) & 0xff),
+               (unsigned)( host        & 0xff));
+
+    // Match net_sdl.c's behaviour: only include :port when non-default,
+    // so default-port strings stay clean for the setup tool / UI.
+    if (pt != DEFAULT_PORT)
+    {
+        char portbuf[10];
+        M_snprintf(portbuf, sizeof(portbuf), ":%u", (unsigned)pt);
+        M_StringConcat(buffer, portbuf, buffer_len);
+    }
+}
+
+net_addr_t *NET_POSIX_ResolveAddress(const char *address)
+{
+    char              *hostname;
+    char              *colon;
+    int                addr_port = port;
+    struct sockaddr_in sa;
+
+    hostname = M_StringDuplicate(address);
+
+    colon = strchr(hostname, ':');
+    if (colon != NULL)
+    {
+        *colon    = '\0';
+        addr_port = atoi(colon + 1);
+    }
+
+    memset(&sa, 0, sizeof(sa));
+    sa.sin_family = AF_INET;
+    sa.sin_port   = htons((uint16_t)addr_port);
+
+    // Numeric-only resolution. The browser-side page passes our
+    // synthetic /24 addresses verbatim (`-connect 10.99.0.1`), so we
+    // never need DNS — and the wasm-posix-kernel's resolver path
+    // (host_getaddrinfo) goes through the page's NetworkBackend,
+    // which doesn't reach the WebRTC relay. Refusing to resolve names
+    // here is the right behaviour: it would either fail loudly
+    // (preferred) or worse, succeed against the wrong network.
+    if (inet_pton(AF_INET, hostname, &sa.sin_addr) != 1)
+    {
+        free(hostname);
+        return NULL;
+    }
+
+    free(hostname);
+    return FindAddress(&sa);
+}
+
+net_module_t net_posix_module =
+{
+    NET_POSIX_InitClient,
+    NET_POSIX_InitServer,
+    NET_POSIX_SendPacket,
+    NET_POSIX_RecvPacket,
+    NET_POSIX_AddrToString,
+    NET_POSIX_FreeAddress,
+    NET_POSIX_ResolveAddress,
+};
+
+// ---------------------------------------------------------------------
+// NET_WaitForLaunch — textscreen-free stub.
+// ---------------------------------------------------------------------
+//
+// chocolate-doom's net_gui.c provides this with a TXT_* desktop drawn
+// onto the screen while the server waits for clients. fbDOOM doesn't
+// link textscreen, so we substitute a headless poll loop that keeps
+// the client and server state machines running until the server
+// flips net_waiting_for_launch off.
+//
+// User-visible behaviour: fbDOOM's pre-game framebuffer freezes for a
+// few netcode round-trips while the handshake completes, then the
+// level loads normally. The doom-mp page surfaces "waiting for player
+// N..." status of its own via the RTT probe (design §7), so the user
+// isn't staring at a blank screen.
+//
+// I_Sleep(1) yields once per spin: this is a cooperatively-scheduled
+// wait, not a busy loop. The wasm-posix-kernel's syscall pressure
+// would already throttle a tight spin, but the explicit sleep keeps
+// the worker thread polite.
+
+extern boolean net_waiting_for_launch;
+
+void NET_WaitForLaunch(void)
+{
+    printf("NET_WaitForLaunch: waiting for server to start the game...\n");
+
+    while (net_waiting_for_launch)
+    {
+        NET_CL_Run();
+        NET_SV_Run();
+        I_Sleep(1);
+    }
+
+    printf("NET_WaitForLaunch: game starting.\n");
+}
