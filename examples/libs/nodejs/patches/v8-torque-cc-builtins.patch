     out() << "  *" << *it << " = " << stack->Pop() << ";\n";
   }
   out() << "  *" << instruction.destination << " = true;\n";
-  out() << "  return;\n";
+  // Non-void functions need `return {};` (value-initialized, caller
+  // doesn't read the result because it already saw `*label_CastError`
