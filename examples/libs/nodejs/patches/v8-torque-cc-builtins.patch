From 8c31ae386742a4b86301c421e518b21c0f459899 Mon Sep 17 00:00:00 2001
From: Brandon Payton <brandon@happycode.net>
Date: Fri, 24 Apr 2026 15:15:55 -0400
Subject: [PATCH 68/94] runtime-macro-shims: add IsInteger +
 SelectBooleanConstant for NumberIsInteger
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Surfaced by whitelisting NumberIsInteger in kCCBuiltins. Two shims:

  IsInteger(Tagged<JSAny>) -> bool        (cast.tq:1311)
  IsInteger(Tagged<HeapNumber>) -> bool   (cast.tq:1312)
  SelectBooleanConstant(bool) -> Boolean  (base.tq:709)

IsInteger: Smi always true; HeapNumber true iff finite and floor(d) == d
(matches Number.isInteger spec — no ToNumber coercion on the JSAny arm).
Both overloads provided because the torque extern signature is declared
for both JSAny and HeapNumber (emitter picks the narrower form if
lowering from a typeswitched HeapNumber arm).

SelectBooleanConstant: no Isolate* in the torque signature, so we reach
for Isolate::Current() (same pattern as NamespaceConstant emission
under kCCBuiltins). ReadOnlyRoots(isolate).true_value()/false_value()
is the same lookup True_0/False_0 do.

No emitter changes required — the two errors were pure shim omissions.
---
 deps/v8/src/torque/runtime-macro-shims.h | 28 ++++++++++++++++++++++++
 1 file changed, 28 insertions(+)

diff --git a/deps/v8/src/torque/runtime-macro-shims.h b/deps/v8/src/torque/runtime-macro-shims.h
index 1a08e200..0243735c 100644
--- a/deps/v8/src/torque/runtime-macro-shims.h
+++ b/deps/v8/src/torque/runtime-macro-shims.h
@@ -97,6 +97,34 @@ inline void BranchIfFloat64IsNaN(double v, bool* label_Taken,
   }
 }
 
+// Phase 6 Task 6.5 — shims added for NumberIsInteger whitelist.
+// IsInteger(v): v is Smi, or HeapNumber d with finite d and floor(d)==d.
+// JSAnyNotNumber → false. Matches Number.isInteger's spec (no ToNumber).
+inline bool IsInteger(Tagged<JSAny> v) {
+  if (IsSmi(v)) return true;
+  if (IsHeapNumber(v)) {
+    double d = Cast<HeapNumber>(v)->value();
+    if (std::isnan(d) || std::isinf(d)) return false;
+    return std::floor(d) == d;
+  }
+  return false;
+}
+// HeapNumber overload — emitter may select this in some lowerings.
+inline bool IsInteger(Tagged<HeapNumber> hn) {
+  double d = hn->value();
+  if (std::isnan(d) || std::isinf(d)) return false;
+  return std::floor(d) == d;
+}
+// SelectBooleanConstant(b) — torque's one-arg form has no Isolate*, so
+// we acquire via Isolate::Current() (same pattern as NamespaceConstant
+// Task 6.2). Preamble-level True_0/False_0 could have been reused, but
+// they take an Isolate* and the torque signature here does not.
+inline Tagged<Boolean> SelectBooleanConstant(bool b) {
+  Isolate* isolate = Isolate::Current();
+  return b ? Cast<Boolean>(ReadOnlyRoots(isolate).true_value())
+           : Cast<Boolean>(ReadOnlyRoots(isolate).false_value());
+}
+
 }  // namespace CodeStubAssembler
 }  // namespace TorqueRuntimeMacroShims
 }  // namespace internal
-- 
