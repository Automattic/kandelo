 void CCGenerator::EmitInstruction(const StoreBitFieldInstruction& instruction,
                                   Stack<std::string>* stack) {
-  ReportError("Not supported in C++ output: StoreBitField");
+  // Mirrors CSAGenerator's StoreBitFieldInstruction emission (see
+  // csa-generator.cc:1008+), but lowered to plain C++ using the
+  // `base::BitField<...>` template directly (no CodeStubAssembler). We
+  // reuse the file-local `GetBitFieldSpecialization` helper that
+  // LoadBitField (cc-generator.cc:565+) already uses.
+  //
+  // Stack layout on entry (top→bottom): value, bit_field_struct. We pop
+  // both, compute the updated container, and push the result name.
+  //
+  // `starts_as_zero` is an optimization hint from the IR: when set, the
+  // container is statically known to be zero at this point, so `encode`
+  // alone suffices (it would otherwise be `encode(value) | (container &
+  // ~kMask)`, which is what `update` computes). Matches CSA's
+  // UpdateWord*(..., /*starts_as_zero=*/true) codepath.
+  //
