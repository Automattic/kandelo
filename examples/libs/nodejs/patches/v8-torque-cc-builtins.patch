 1 file changed, 37 insertions(+), 1 deletion(-)

diff --git a/deps/v8/src/torque/cc-generator.cc b/deps/v8/src/torque/cc-generator.cc
index da7fb816..d459a3b7 100644
--- a/deps/v8/src/torque/cc-generator.cc
+++ b/deps/v8/src/torque/cc-generator.cc
@@ -511,7 +511,43 @@ void CCGenerator::EmitInstruction(const LoadReferenceInstruction& instruction,
 
 void CCGenerator::EmitInstruction(const StoreReferenceInstruction& instruction,
                                   Stack<std::string>* stack) {
-  ReportError("Not supported in C++ output: StoreReference");
+  // We should never load or store builtin pointers because the heap may be
+  // corrupted (mirrors CSAGenerator::EmitInstruction for this instruction).
+  CHECK(!instruction.type->IsBuiltinPointerType());
+
+  std::string value = stack->Pop();
+  std::string offset = stack->Pop();
+  std::string object = stack->Pop();
+
+  if (is_cc_debug_) {
+    ReportError("Not supported in C++ output: StoreReference in debug");
+  }
+
+  // Note: unlike LoadReferenceInstruction, StoreReferenceInstruction does not
+  // carry a FieldSynchronization — @cppRelaxedStore / @cppReleaseStore do not
+  // exist in Torque. We therefore only emit the plain (release-barrier-free)
+  // store variants.
+  std::string result_type = instruction.type->GetRuntimeType();
+  if (instruction.type->IsSubtypeOf(TypeOracle::GetTaggedType())) {
+    // Symmetric with LoadReference: only smi tagged values are handled today;
+    // plumb PtrComprCageBase through generated code once we need to store
+    // HeapObject-typed fields.
+    if (!instruction.type->IsSubtypeOf(TypeOracle::GetSmiType())) {
+      Error(
+          "Not supported in C++ output: StoreReference on non-smi tagged "
+          "value");
+    }
+    // References and slices can cause some values to have the Torque type
+    // HeapObject|TaggedZeroPattern, which is output as "Object". TaggedField
+    // requires HeapObject, so we need a cast.
+    out() << "  TaggedField<" << result_type
+          << ">::store(UncheckedCast<HeapObject>(" << object
+          << "), static_cast<int>(" << offset << "), " << value << ");\n";
+  } else {
+    // Mirror the untagged LoadReference path which uses ReadField.
+    out() << "  (" << object << ")->WriteField<" << result_type << ">("
+          << offset << ", " << value << ");\n";
+  }
 }
 
