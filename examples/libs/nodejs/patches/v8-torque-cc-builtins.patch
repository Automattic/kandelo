+  // Returns the entry address for a Torque-translated TFJ builtin that was
+  // emitted by the kCCBuiltins backend (kind: kStub, non-JS-linkage,
+  // whitelisted via --cc-builtins-whitelist). Returns Address{} for any
+  // other builtin. The set of dispatched builtins is generated by torque
+  // into torque-generated/builtins-cc-table.inc.
+  static Address TorqueCcEntryOf(Builtin builtin);
+
   // Loads the builtin's entry (start of instruction stream) from the isolate's
   // builtin_entry_table, initialized earlier via {InitializeIsolateDataTables}.
   static inline Address EntryOf(Builtin builtin, Isolate* isolate);
