 deps/v8/src/torque/cc-generator.h            |  9 +++++++++
 deps/v8/src/torque/implementation-visitor.cc | 12 ++++++++++++
 3 files changed, 30 insertions(+), 1 deletion(-)

diff --git a/deps/v8/src/torque/cc-generator.cc b/deps/v8/src/torque/cc-generator.cc
index 48e3f52a..9e496eef 100644
--- a/deps/v8/src/torque/cc-generator.cc
+++ b/deps/v8/src/torque/cc-generator.cc
@@ -728,7 +728,15 @@ void CCGenerator::EmitInstruction(const GotoExternalInstruction& instruction,
     out() << "  *" << *it << " = " << stack->Pop() << ";\n";
   }
   out() << "  *" << instruction.destination << " = true;\n";
-  out() << "  return;\n";
+  // Non-void functions need `return {};` (value-initialized, caller
+  // doesn't read the result because it already saw `*label_CastError`
+  // set). For void/never functions, bare `return;` is correct — emit
+  // that when the enclosing function has no value return.
+  if (external_goto_returns_value_) {
+    out() << "  return {};\n";
+  } else {
+    out() << "  return;\n";
+  }
 }
 
 void CCGenerator::EmitInstruction(const ReturnInstruction& instruction,
