+// Copyright 2026 Node.js contributors. All rights reserved.
+// Phase 5 (Task 5.6) — helper implementation for
+// test_torque_cc_builtin.cc. See test_torque_cc_builtin_helpers.h for
+// the rationale on why this lives in a separate translation unit.
+//
+// IMPORTANT: do NOT include node_test_fixture.h, node_internals.h, or
+// anything from Node's src/tracing/ here. The V8 internal includes
+// below transitively pull in src/heap/heap.h → src/heap/gc-tracer.h
+// → src/tracing/trace-event.h, whose TRACE_EVENT0 macro and
+// CategoryGroupEnabledFlags enum collide with Node's same-named
+// definitions from src/tracing/trace_event_common.h.
+
+#include "test_torque_cc_builtin_helpers.h"
+
+#include "src/api/api-inl.h"
+#include "src/execution/isolate-inl.h"
+#include "src/heap/factory.h"
+#include "src/objects/js-objects.h"
+#include "src/objects/property-details.h"
+
+namespace torque_cc_test {
+
+void BindJsReturnBuiltinOnGlobal(v8::Isolate* isolate) {
+  v8::internal::Isolate* i_isolate =
+      reinterpret_cast<v8::internal::Isolate*>(isolate);
+  v8::internal::HandleScope scope(i_isolate);
+
+  v8::internal::DirectHandle<v8::internal::NativeContext> native_ctx =
+      i_isolate->native_context();
+
+  v8::internal::DirectHandle<v8::internal::String> name =
+      i_isolate->factory()->NewStringFromAsciiChecked("TorqueCcTest_JsReturn");
+
+  // len=1 matches the CPP listing's JSParameterCount(1) on the
+  // TorqueCcTest_JsReturn builtin. kAdapt (AdaptArguments::kYes) routes
+  // the call through AdaptorWithBuiltinExitFrame1, which is what the
+  // test is exercising.
+  v8::internal::DirectHandle<v8::internal::SharedFunctionInfo> sfi =
+      i_isolate->factory()->NewSharedFunctionInfoForBuiltin(
+          name, v8::internal::Builtin::kTorqueCcTest_JsReturn,
+          /*len=*/1, v8::internal::kAdapt);
+
+  v8::internal::DirectHandle<v8::internal::JSFunction> fn =
+      v8::internal::Factory::JSFunctionBuilder{i_isolate, sfi, native_ctx}
+          .Build();
+
+  v8::internal::DirectHandle<v8::internal::JSObject> global(
+      i_isolate->global_object());
+  v8::internal::JSObject::AddProperty(i_isolate, global, name, fn,
+                                      v8::internal::NONE);
+}
