From 86e916eb0c66458070560685fe84ca29a0a31644 Mon Sep 17 00:00:00 2001
From: Brandon Payton <brandon@happycode.net>
Date: Sat, 25 Apr 2026 11:14:53 -0400
Subject: [PATCH 82/94] cctest: add ScriptRunIncrement and
 ScriptRunIncrementBigInt
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

First real-world end-to-end tail-call cctest. `ScriptRunIncrement`
exercises CCGenerator's tail-call branch through V8's Script::Run
pipeline → JS-linkage adaptor → Builtin_Increment → tail-call
Builtin_Add (the inline C bridge in implementation-visitor.cc's
preamble that wraps Number+Number arithmetic). Cases cover all four
UnaryOp1 arms:
- Smi: ++0 → 1, ++41 → 42, ++-1 → 0
- HeapNumber via Smi-overflow: ++MAX_SAFE_INTEGER → 2^53
- Non-integer HeapNumber: ++1.5 → 2.5, ++-0.5 → 0.5
- JSAnyNotNumeric coercion via Builtin_NonNumberToNumeric:
  ++"41" → 42, ++null → 1, ++true → 2

`ScriptRunIncrementBigInt` covers the BigInt label arm (no tail-call
here — flows into runtime::BigIntUnaryOp). Validates that the
non-tail kCCBuiltins path still works post-Isolate::Current()
substitution.
---
 test/cctest/test_torque_cc_builtin.cc | 75 +++++++++++++++++++++++++++
 1 file changed, 75 insertions(+)

diff --git a/test/cctest/test_torque_cc_builtin.cc b/test/cctest/test_torque_cc_builtin.cc
index 25465c12..68cdc7a7 100644
--- a/test/cctest/test_torque_cc_builtin.cc
+++ b/test/cctest/test_torque_cc_builtin.cc
@@ -346,3 +346,78 @@ TEST_F(TorqueCcBuiltinTest, DirectInvocationTorqueCcTest_TailCall) {
     EXPECT_EQ(v8::internal::Smi::ToInt(result), value) << "input: " << value;
   }
 }
+
+// Phase 8 — Increment is the first real-world tail-call forcing target
+// to actually ship under kCCBuiltins. Its torque body
+// (`tail Add(n, 1)` on the Number arm) exercises CCGenerator's tail-call
+// branch through to the shipping `Builtin_Add` C bridge in the
+// implementation-visitor.cc preamble. UnaryOp1's JSAnyNotNumeric arm
+// flows into `Builtin_NonNumberToNumeric`, exercising the second
+// inline-bridge shim. Cases cover every UnaryOp1 arm:
+//   - Smi (++0 → 1, ++41 → 42; Smi+Smi never overflows here since the
+//     constant is 1 and inputs stay well within Smi range)
+//   - HeapNumber via Smi-overflow (++MAX_SAFE_INTEGER), non-integer
+//     HeapNumber (++1.5)
+//   - JSAnyNotNumeric coercion path (++"41", ++null, ++true) routed
+//     through Builtin_NonNumberToNumeric → Object::ToNumeric
+//   - BigInt arm covered separately below (different result type).
+TEST_F(TorqueCcBuiltinTest, ScriptRunIncrement) {
+  v8::HandleScope scope(isolate_);
+  v8::Local<v8::Context> ctx = v8::Context::New(isolate_);
+  v8::Context::Scope cscope(ctx);
+
+  struct Case { const char* source; double expected; };
+  const Case cases[] = {
+      {"(function(){var x=0; return ++x;})()", 1.0},
+      {"(function(){var x=41; return ++x;})()", 42.0},
+      {"(function(){var x=-1; return ++x;})()", 0.0},
+      {"(function(){var x=Number.MAX_SAFE_INTEGER; return ++x;})()",
+       9007199254740992.0},
+      {"(function(){var x=1.5; return ++x;})()", 2.5},
+      {"(function(){var x=-0.5; return ++x;})()", 0.5},
+      {"(function(){var x='41'; return ++x;})()", 42.0},
+      {"(function(){var x=null; return ++x;})()", 1.0},
+      {"(function(){var x=true; return ++x;})()", 2.0},
+  };
+  for (const auto& c : cases) {
+    v8::Local<v8::String> src =
+        v8::String::NewFromUtf8(isolate_, c.source).ToLocalChecked();
+    v8::Local<v8::Script> script =
+        v8::Script::Compile(ctx, src).ToLocalChecked();
+    v8::Local<v8::Value> result = script->Run(ctx).ToLocalChecked();
+    EXPECT_TRUE(result->IsNumber()) << "source: " << c.source;
+    EXPECT_EQ(result->NumberValue(ctx).ToChecked(), c.expected)
+        << "source: " << c.source;
+  }
+}
+
+// Phase 8 — BigInt arm of Increment. ++1n exits UnaryOp1 via the
+// BigInt label and dispatches into runtime::BigIntUnaryOp (no
+// Builtin_Add tail-call here — only the Number arm tail-calls Add).
+// Smoke-tests that the BigInt path remains correct under the
+// kCCBuiltins dispatch.
+TEST_F(TorqueCcBuiltinTest, ScriptRunIncrementBigInt) {
+  v8::HandleScope scope(isolate_);
+  v8::Local<v8::Context> ctx = v8::Context::New(isolate_);
+  v8::Context::Scope cscope(ctx);
+
+  struct Case { const char* source; int64_t expected; };
+  const Case cases[] = {
+      {"(function(){var x=0n; return ++x;})()", 1},
+      {"(function(){var x=1n; return ++x;})()", 2},
+      {"(function(){var x=-1n; return ++x;})()", 0},
+      {"(function(){var x=42n; return ++x;})()", 43},
+  };
+  for (const auto& c : cases) {
+    v8::Local<v8::String> src =
+        v8::String::NewFromUtf8(isolate_, c.source).ToLocalChecked();
+    v8::Local<v8::Script> script =
+        v8::Script::Compile(ctx, src).ToLocalChecked();
+    v8::Local<v8::Value> result = script->Run(ctx).ToLocalChecked();
+    EXPECT_TRUE(result->IsBigInt()) << "source: " << c.source;
+    bool lossless = false;
+    EXPECT_EQ(result.As<v8::BigInt>()->Int64Value(&lossless), c.expected)
+        << "source: " << c.source;
+    EXPECT_TRUE(lossless) << "source: " << c.source;
+  }
+}
