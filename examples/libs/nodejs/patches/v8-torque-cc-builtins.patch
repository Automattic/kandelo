+    std::string cc_builtins_fwd_decls =
+        streams.cc_builtins_headerfile.str();
     std::string cc_builtins_preamble =
         "// Copyright 2024 the V8 project authors. All rights reserved.\n"
         "// Use of this source code is governed by a BSD-style license that "
@@ -2197,15 +2206,30 @@ void ImplementationVisitor::GenerateImplementation(const std::string& dir) {
         "#include \"src/objects/smi.h\"\n"
