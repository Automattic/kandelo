From 78e36e8965749dbd4101599d2f18b0ce560ac0c2 Mon Sep 17 00:00:00 2001
From: Brandon Payton <brandon@happycode.net>
Date: Mon, 20 Apr 2026 23:53:34 -0400
Subject: [PATCH 08/10] torque: filter fourth pass to Builtin declarables only

Task 1.6 landed the fourth pass as the plan specified, iterating every
declarable. Smoke-testing on the 245-file stock fileset under kCCBuiltins
SIGSEGVs: Visit(NamespaceConstant*) unconditionally drives CSAGenerator
and the assembler in a state that's only safe in the first (kCSA) pass,
and Visit(TorqueMacro)/Visit(Method) re-enter VisitMacroCommon which
runs the full inlining/assembler machinery even when streams are nulled.

The kCC and kCCDebug passes avoid this by iterating curated macro lists
(AllMacrosForCCOutput / AllMacrosForCCDebugOutput). The kCCBuiltins pass
has no analogous curated list yet, so we inline the filter in the loop:
only kBuiltin declarables produce output here. Phase 2 can widen this
if needed.

With the filter, torque exits 0 on the full stock fileset.
---
 deps/v8/src/torque/implementation-visitor.cc | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/deps/v8/src/torque/implementation-visitor.cc b/deps/v8/src/torque/implementation-visitor.cc
index 54551d20..ae96de1b 100644
--- a/deps/v8/src/torque/implementation-visitor.cc
+++ b/deps/v8/src/torque/implementation-visitor.cc
@@ -3588,8 +3588,18 @@ void ImplementationVisitor::VisitAllDeclarables() {
   }
 
   // Do the same for builtins, which generate C++ builtin definitions.
+  // Only visit Builtin declarables in this pass: the other Callables
+  // (TorqueMacro, Method) and non-Callable Values (NamespaceConstant) run
+  // machinery that is not safe to re-enter under kCCBuiltins — they would
+  // drive CSAGenerator/assembler against state intended only for the kCSA
+  // first pass and crash (SIGSEGV) for NamespaceConstants, or emit stray
+  // cpp-file content for inlined macros. The kCC and kCCDebug passes avoid
+  // this by iterating curated macro lists; Phase 1 matches that pattern by
+  // filtering here. Phase 2 can widen this if additional declarable kinds
+  // need to drive kCCBuiltins emission.
   output_type_ = OutputType::kCCBuiltins;
   for (size_t i = 0; i < all_declarables.size(); ++i) {
+    if (all_declarables[i]->kind() != Declarable::kBuiltin) continue;
     try {
       Visit(all_declarables[i].get());
     } catch (TorqueAbortCompilation&) {
