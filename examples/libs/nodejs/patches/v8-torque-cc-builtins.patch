 1 file changed, 39 insertions(+), 1 deletion(-)

diff --git a/deps/v8/src/torque/cc-generator.cc b/deps/v8/src/torque/cc-generator.cc
index 406e09b3..ac2e28a6 100644
--- a/deps/v8/src/torque/cc-generator.cc
+++ b/deps/v8/src/torque/cc-generator.cc
@@ -361,7 +361,45 @@ void CCGenerator::EmitInstruction(const CallBuiltinInstruction& instruction,
 void CCGenerator::EmitInstruction(
     const CallBuiltinPointerInstruction& instruction,
     Stack<std::string>* stack) {
-  ReportError("Not supported in C++ output: CallBuiltinPointer");
+  if (instruction.is_tailcall) {
+    ReportError("Phase 2: CallBuiltinPointer tail-call is deferred.");
+  }
+  std::vector<std::string> arguments = stack->PopMany(instruction.argc);
+  std::string function = stack->Pop();
+  std::vector<const Type*> result_types =
+      LowerType(instruction.type->return_type());
+  if (result_types.size() != 1) {
+    ReportError("builtin pointers must have exactly one result");
+  }
+  std::string result_name =
+      DefinitionToVariable(instruction.GetValueDefinition(0));
+  decls() << "  " << result_types[0]->GetRuntimeType() << " " << result_name
+          << "{};  USE(" << result_name << ");\n";
+  stack->Push(result_name);
+
+  // Phase 2 placeholder: resolve the BuiltinPtr (Tagged<Smi> carrying the
+  // Builtin enum id — see PushBuiltinPointerInstruction emission above) to
+  // a raw function pointer via Builtins::CppEntryOf(...) and invoke it
+  // directly. `Builtins::CppEntryOf` does not yet exist — Phase 4 will
+  // introduce it alongside a generated `builtins-cc-table.inc` that maps
+  // Builtin enum ids to Builtin_* entry addresses. For Phase 2 we only
+  // need the emission to be syntactically valid C++ and to capture the
+  // correct signature shape for the call.
+  out() << "  {\n"
+        << "    using FnPtr = " << result_types[0]->GetRuntimeType()
+        << " (*)(Isolate*";
+  const TypeVector& params = instruction.type->parameter_types();
+  for (const Type* param : params) {
+    out() << ", " << param->GetRuntimeType();
+  }
+  out() << ");\n"
+        << "    FnPtr fn = reinterpret_cast<FnPtr>(\n"
+        << "        Builtins::CppEntryOf(static_cast<Builtin>(\n"
+        << "            Smi::ToInt(" << function << "))));\n"
+        << "    " << result_name << " = fn(isolate";
+  for (const auto& arg : arguments) out() << ", " << arg;
+  out() << ");\n"
+        << "  }\n";
 }
 
