Subject: [PATCH 36/59] torque: emit builtins-cc-table.inc for kCCBuiltins
 dispatch

---
 deps/v8/src/torque/implementation-visitor.cc | 47 ++++++++++++++++++++
 deps/v8/src/torque/implementation-visitor.h  | 16 +++++++
 deps/v8/src/torque/torque-compiler.cc        |  4 ++
 3 files changed, 67 insertions(+)

diff --git a/deps/v8/src/torque/implementation-visitor.cc b/deps/v8/src/torque/implementation-visitor.cc
index 4822e07f..2d147a1d 100644
--- a/deps/v8/src/torque/implementation-visitor.cc
+++ b/deps/v8/src/torque/implementation-visitor.cc
@@ -694,6 +694,21 @@ void ImplementationVisitor::Visit(Builtin* builtin) {
     cc_generator.EmitGraph(parameters);
     assembler_ = std::nullopt;
     csa_ccfile() << "}\n\n";
+
+    // Record this builtin for emission into
+    // torque-generated/builtins-cc-table.inc so
+    // Builtins::TorqueCcEntryOf(Builtin::k<Name>) can resolve to
+    // &Builtin_<Name> at runtime. The X-macro's V(Name, Ret, Params) uses
+    // `Name` to generate both the forward declaration (Builtin_##Name) and
+    // the enum key (Builtin::k##Name), so strip any prefix and store the
+    // bare external name here.
+    CCBuiltinEntry entry;
+    entry.name = name;
+    entry.return_type = signature.return_type->GetRuntimeType();
+    for (size_t i = 0; i < signature.parameter_names.size(); ++i) {
+      entry.param_types.push_back(signature.types()[i]->GetRuntimeType());
+    }
+    cc_builtin_entries_.push_back(std::move(entry));
     return;
   }
   CurrentScope::Scope current_scope(builtin);
@@ -4241,6 +4256,38 @@ void ImplementationVisitor::GenerateBitFields(
   WriteFile(output_header_path, header.str());
 }
 
+void ImplementationVisitor::GenerateCCBuiltinsTable(
+    const std::string& output_directory) {
+  // Emit a shared X-macro file listing every whitelisted kCCBuiltins builtin
+  // that was emitted during this torque invocation. Consumers (builtins.cc
+  // via Builtins::TorqueCcEntryOf) expand TORQUE_CC_BUILTINS(V) to generate
+  // forward declarations and a Builtin→function-pointer dispatch switch.
+  //
+  // Linkage note: the forward declarations expanded from this macro match
+  // the C++-linkage function signatures emitted in -tq-ccbuiltins.cc —
+  // callers (TorqueCcEntryOf) do not use `extern "C"`. kCCBuiltins builtins
+  // are invoked only by function pointer through TorqueCcEntryOf, so name
+  // mangling is irrelevant at the call site.
+  std::string file_name = "builtins-cc-table.inc";
+  std::stringstream out;
+  out << "// Copyright 2024 the V8 project authors. All rights reserved.\n"
+      << "// Use of this source code is governed by a BSD-style license "
+         "that can be found in the LICENSE file.\n\n"
+      << "// AUTO-GENERATED by torque CC-Builtins backend. DO NOT EDIT.\n\n"
+      << "#ifndef TORQUE_CC_BUILTINS\n"
+      << "#define TORQUE_CC_BUILTINS(V) \\\n";
+  for (const auto& e : cc_builtin_entries_) {
+    out << "  V(" << e.name << ", " << e.return_type << ", (Isolate*";
+    for (const auto& p : e.param_types) {
+      out << ", " << p;
+    }
+    out << ")) \\\n";
+  }
+  out << "\n#endif  // TORQUE_CC_BUILTINS\n";
+
+  WriteFile(output_directory + "/" + file_name, out.str());
+}
+
 namespace {
 
 class ClassFieldOffsetGenerator : public FieldOffsetsGenerator {
