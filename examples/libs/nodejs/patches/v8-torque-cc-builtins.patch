+  // via CallRuntimeInstruction from inside a Builtin body and need their
+  // arguments pushed onto the Torque stack. Inlining here would skip stack
+  // population and trigger "wrong argument types" at type-instruction time.
+  bool ShouldBeInlined(OutputType output_type) const override {
+    if (output_type == OutputType::kCCBuiltins) return false;
+    return Callable::ShouldBeInlined(output_type);
+  }
 
  private:
   friend class Declarations;
