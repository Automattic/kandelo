 2 files changed, 43 insertions(+)

diff --git a/deps/v8/src/builtins/builtins.cc b/deps/v8/src/builtins/builtins.cc
index 585f4d67..211126f7 100644
--- a/deps/v8/src/builtins/builtins.cc
+++ b/deps/v8/src/builtins/builtins.cc
@@ -352,6 +352,42 @@ Address Builtins::CppEntryOf(Builtin builtin) {
   return builtin_metadata[ToInt(builtin)].data.cpp_entry;
 }
 
+// Forward declarations for every Torque-translated TFJ builtin emitted by
+// the kCCBuiltins backend. The table is (re)generated by torque into
+// torque-generated/builtins-cc-table.inc on every torque run. If no builtin
+// is whitelisted the macro is left undefined and the #ifdef guards below
+// make TorqueCcEntryOf a pure Address{} fallback.
+//
+// Linkage note: these declarations use default C++ linkage (no `extern "C"`)
+// to match the signatures emitted in *-tq-ccbuiltins.cc. Name mangling
+// does not matter at the call site because kCCBuiltins builtins are invoked
+// exclusively by function pointer through TorqueCcEntryOf.
+#include "torque-generated/builtins-cc-table.inc"
+#ifdef TORQUE_CC_BUILTINS
+#define DECLARE_TQCC_FORWARD(Name, RetType, ParamTypes) \
+  RetType Builtin_##Name ParamTypes;
+TORQUE_CC_BUILTINS(DECLARE_TQCC_FORWARD)
+#undef DECLARE_TQCC_FORWARD
+#endif
+
+// static
+Address Builtins::TorqueCcEntryOf(Builtin builtin) {
+#ifdef TORQUE_CC_BUILTINS
+  switch (builtin) {
+#define CASE(Name, RetType, ParamTypes) \
+  case Builtin::k##Name:                \
+    return reinterpret_cast<Address>(&Builtin_##Name);
+    TORQUE_CC_BUILTINS(CASE)
+#undef CASE
+    default:
+      break;
+  }
+#else
+  USE(builtin);
+#endif
+  return Address{};
+}
+
 // static
 bool Builtins::IsBuiltin(const Tagged<Code> code) {
   return Builtins::IsBuiltinId(code->builtin_id());
