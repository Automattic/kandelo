 deps/v8/src/torque/cc-generator.cc | 21 ++++++++++++++++++++-
 1 file changed, 20 insertions(+), 1 deletion(-)

diff --git a/deps/v8/src/torque/cc-generator.cc b/deps/v8/src/torque/cc-generator.cc
index 9b452f95..b9e216db 100644
--- a/deps/v8/src/torque/cc-generator.cc
+++ b/deps/v8/src/torque/cc-generator.cc
@@ -639,7 +639,26 @@ void CCGenerator::EmitInstruction(const GotoInstruction& instruction,
 
 void CCGenerator::EmitInstruction(const GotoExternalInstruction& instruction,
                                   Stack<std::string>* stack) {
-  ReportError("Not supported in C++ output: GotoExternal");
+  // Callee-side complement to CallCsaMacroAndBranchInstruction's caller-side
+  // out-param rewrite (cc-generator.cc above, Phase 3 Task 3.5): the macro
+  // body's signature replaces each CodeAssemblerLabel* param with a
+  // `bool* <destination>` + `T* <variable_names[i]>` group. This instruction
+  // fires when Torque's body-CFG encounters `goto <ExternalLabel>(...)`:
+  // we write each out-param slot in reverse stack order, set the label
+  // flag to true, and return.
+  //
+  // Phase 3 note: this emission is not exercised by the Phase 3 fixture
+  // set because kCCBuiltins does not yet emit standalone labeled-macro
+  // bodies (no kCCBuiltins-macro iteration pass; no relaxation of the
+  // existing GenerateFunction `ReportError` gate at
+  // implementation-visitor.cc:2056-2058 for non-CC paths). When a later
+  // phase adds that emission path, this code runs as-is.
+  for (auto it = instruction.variable_names.rbegin();
+       it != instruction.variable_names.rend(); ++it) {
+    out() << "  *" << *it << " = " << stack->Pop() << ";\n";
+  }
+  out() << "  *" << instruction.destination << " = true;\n";
+  out() << "  return;\n";
 }
 
