     }
     std::vector<std::string> arguments = stack->PopMany(instruction.argc);
+    // Phase 8: under kCCBuiltins, CallBuiltin emissions can appear inside
+    // helper-macro bodies (emitted via EnsureInCCBuiltinsOutputList) that
+    // do NOT have an `Isolate*` parameter — only the outer JS-linkage
+    // builtin body has `isolate` in scope. Use `Isolate::Current()` to
+    // make both contexts compile (parallel to Phase 6.1's I-1 pattern
+    // for `True_0()` / `False_0()`). The TLS read is single-digit ns
+    // and avoids a per-helper-signature isolate-injection refactor.
+    const char* isolate_token = is_cc_builtins_ ? "Isolate::Current()" : "isolate";
     out() << "  return Builtin_" << instruction.builtin->ExternalName()
