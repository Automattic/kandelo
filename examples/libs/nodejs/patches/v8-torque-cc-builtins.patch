+      // Unpack implicit parameters (context / receiver / newTarget /
+      // target / dispatchHandle) from BuiltinArguments + isolate.
+      for (size_t i = 0; i < signature.implicit_count; ++i) {
+        const std::string& param_name = signature.parameter_names[i]->value;
+        SourcePosition param_pos = signature.parameter_names[i]->pos;
+        const Type* type = signature.types()[i];
+        const bool mark_as_used = signature.implicit_count > i;
+        std::string generated_name =
+            AddParameter(i, builtin, &parameters, &parameter_types,
+                         &parameter_bindings, mark_as_used);
+
+        if (param_name == "context") {
+          csa_ccfile() << "  Tagged<NativeContext> " << generated_name
+                       << " = Cast<NativeContext>(isolate->context());\n";
+        } else if (param_name == "receiver") {
+          csa_ccfile() << "  Tagged<JSAny> " << generated_name
+                       << " = Cast<JSAny>(*args.receiver());\n";
+        } else if (param_name == "newTarget") {
+          csa_ccfile() << "  Tagged<JSAny> " << generated_name
+                       << " = Cast<JSAny>(*args.new_target());\n";
+        } else if (param_name == "target") {
+          csa_ccfile() << "  Tagged<JSFunction> " << generated_name
+                       << " = *args.target();\n";
+        } else if (param_name == "dispatchHandle") {
+          csa_ccfile() << "  JSDispatchHandle " << generated_name
+                       << " = InvalidDispatchHandleConstant();\n";
+        } else {
+          Error("Unexpected implicit parameter \"", param_name,
+                "\" for JavaScript calling convention, expected "
+                "\"context\", \"receiver\", \"target\", \"newTarget\", "
+                "or \"dispatchHandle\"")
+              .Position(param_pos);
+        }
+        csa_ccfile() << "  USE(" << generated_name << ");\n";
+
+        // Bridge from the `parameterN` stack slot name (what CCGenerator
+        // expects) to the Torque-source parameter name (what the lowered
+        // body references). Same pattern as the stub-linkage branch
+        // above.
+        csa_ccfile() << "  " << type->GetRuntimeType() << " " << param_name
+                     << " = " << generated_name << ";\n";
+        csa_ccfile() << "  USE(" << param_name << ");\n";
+      }
+
+      // Unpack explicit parameters from args[i]. Zero-indexed past
+      // receiver — `args[0]` is the first explicit arg, NOT the receiver.
+      for (size_t i = signature.implicit_count;
+           i < signature.parameter_names.size(); ++i) {
+        const std::string& param_name = signature.parameter_names[i]->value;
+        const Type* type = signature.types()[i];
+        const bool mark_as_used = signature.implicit_count > i;
+        std::string generated_name =
+            AddParameter(i, builtin, &parameters, &parameter_types,
+                         &parameter_bindings, mark_as_used);
+        size_t explicit_index = i - signature.implicit_count;
+        const std::string& runtime_type = type->GetRuntimeType();
+        // Strip `Tagged<` prefix and `>` suffix so we can fit the inner
+        // type into `Cast<Inner>(args[i])`. JS-linkage ABI carries tagged
+        // values, so the explicit-arg runtime type should always be
+        // `Tagged<...>`; struct/raw-word explicit params are not a
+        // legal JS-linkage shape.
+        std::string inner_type =
+            runtime_type.substr(7, runtime_type.size() - 8);
+        csa_ccfile() << "  " << runtime_type << " " << generated_name
+                     << " = Cast<" << inner_type << ">(args[" << explicit_index
+                     << "]);\n"
+                     << "  USE(" << generated_name << ");\n";
+
+        // Bridge line — same pattern as the implicit case.
+        csa_ccfile() << "  " << runtime_type << " " << param_name << " = "
+                     << generated_name << ";\n"
+                     << "  USE(" << param_name << ");\n";
+      }
+
+      // Drive Torque body through CCGenerator, same as stub-linkage, but
+      // with kPtrReturn so the `return <tagged>;` becomes
+      // `return <tagged>.ptr();` to match the CPP-ABI Address return
+      // slot.
+      assembler_ = CfgAssembler(parameter_types);
+      const Type* body_result = Visit(*builtin->body());
+      if (body_result != TypeOracle::GetNeverType()) {
+        ReportError(
+            "control reaches end of builtin, expected return of a value");
+      }
+      CCGenerator cc_generator{assembler().Result(), csa_ccfile()};
+      cc_generator.SetReturnMode(CCGenerator::ReturnMode::kPtrReturn);
+      cc_generator.EmitGraph(parameters);
+      assembler_ = std::nullopt;
+      csa_ccfile() << "}\n\n";
+
+      // Do NOT push to cc_builtin_entries_: JS-linkage builtins are
+      // dispatched through V8's CPP adaptor pipeline, not through
+      // Builtins::TorqueCcEntryOf. Keep builtins-cc-table.inc scoped
+      // to stub-linkage only.
       return;
     }
 
