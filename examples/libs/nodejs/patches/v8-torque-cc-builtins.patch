     std::string cc_builtins_body = streams.cc_builtins_ccfile.str();
+    // Forward declarations for the TqRuntime<name>_<N> macro functions
+    // whose inline bodies are appended to cc_builtins_ccfile by the
+    // kCCBuiltins fifth pass (Visit(TorqueMacro*) via VisitMacroCommon
+    // — see f.PrintDeclaration(csa_headerfile()) at line ~412).
+    // Without these forward decls, builtin bodies (emitted earlier in
+    // the same TU by the kCCBuiltins fourth pass) would reference the
+    // macros before their definitions appear — a compile error in C++.
+    std::string cc_builtins_fwd_decls =
