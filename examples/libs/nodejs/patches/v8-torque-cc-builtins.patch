Subject: [PATCH 66/94] cctest: add ScriptRunNumberIsFinite
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Phase 6 Task 6.2 — end-to-end verification of the NumberIsFinite
whitelist. Exercises the JSBuiltinInvoker -> CPP-ABI adaptor
-> Torque-CC-emitted Builtin_NumberIsFinite dispatch chain through
Script::Run (same harness shape as ScriptRunArrayIsArray).

11 subcases cover:
  - Finite numbers: 0, 1.5, -1.5 (Smi + HeapNumber paths).
  - Infinities: Infinity, -Infinity (HeapNumber NaN-probe arm).
  - NaN (HeapNumber NaN-probe arm).
  - Non-numbers: string, null, undefined, plain object (all false).
  - Number wrapper (new Number(0)) — per spec Number.isFinite does
    NOT unwrap; boxed wrappers are not finite. This case catches
    ABI-plumbing bugs that silently coerce the receiver.

Asserts TorqueCcBuiltinTest: 5 -> 6 PASS.
---
 test/cctest/test_torque_cc_builtin.cc | 41 +++++++++++++++++++++++++++
 1 file changed, 41 insertions(+)

diff --git a/test/cctest/test_torque_cc_builtin.cc b/test/cctest/test_torque_cc_builtin.cc
index 2f4e7fb3..b9222d1d 100644
--- a/test/cctest/test_torque_cc_builtin.cc
+++ b/test/cctest/test_torque_cc_builtin.cc
@@ -156,3 +156,44 @@ TEST_F(TorqueCcBuiltinTest, ScriptRunArrayIsArray) {
         << "source: " << c.source;
   }
 }
+
+// Phase 6 Task 6.2 — end-to-end verification of the NumberIsFinite
+// whitelist. Exercises the same JSBuiltinInvoker -> CPP-ABI adaptor
+// chain as ScriptRunArrayIsArray, but the Torque-CC-emitted body
+// fans out through a typeswitch (Smi fast-path returns true;
+// HeapNumber goes through (v - v) NaN probe via BranchIfFloat64IsNaN;
+// everything else returns false). Eleven subcases cover finite Smis,
+// floats, +/-Infinity, NaN, string, null, undefined, plain object, and
+// a Number wrapper object — the spec says Number.isFinite(new Number(0))
+// is false (no ToNumber coercion) which catches ABI-plumbing bugs that
+// silently unwrap the receiver.
+TEST_F(TorqueCcBuiltinTest, ScriptRunNumberIsFinite) {
+  v8::HandleScope scope(isolate_);
+  v8::Local<v8::Context> ctx = v8::Context::New(isolate_);
+  v8::Context::Scope cscope(ctx);
+
+  struct Case { const char* source; bool expected; };
+  const Case cases[] = {
+      {"Number.isFinite(0)",            true},
+      {"Number.isFinite(1.5)",          true},
+      {"Number.isFinite(-1.5)",         true},
+      {"Number.isFinite(Infinity)",     false},
+      {"Number.isFinite(-Infinity)",    false},
+      {"Number.isFinite(NaN)",          false},
+      {"Number.isFinite('0')",          false},
+      {"Number.isFinite(null)",         false},
+      {"Number.isFinite(undefined)",    false},
+      {"Number.isFinite({})",           false},
+      {"Number.isFinite(new Number(0))",false},  // per spec
+  };
+  for (const auto& c : cases) {
+    v8::Local<v8::String> src =
+        v8::String::NewFromUtf8(isolate_, c.source).ToLocalChecked();
+    v8::Local<v8::Script> script =
+        v8::Script::Compile(ctx, src).ToLocalChecked();
+    v8::Local<v8::Value> result = script->Run(ctx).ToLocalChecked();
+    EXPECT_TRUE(result->IsBoolean()) << "source: " << c.source;
+    EXPECT_EQ(result->BooleanValue(isolate_), c.expected)
+        << "source: " << c.source;
+  }
+}
