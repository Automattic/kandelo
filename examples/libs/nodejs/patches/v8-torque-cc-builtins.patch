From f279deb8968a7c7d0a0c085287b20a2a93f117b2 Mon Sep 17 00:00:00 2001
From: wasm-posix-kernel build <build@wasm-posix-kernel.local>
Date: Tue, 21 Apr 2026 14:19:47 -0400
Subject: [PATCH 26/27] torque: implement
 CCGenerator::Emit(CallCsaMacroAndBranchInstruction)

Emits the out-param rewrite pattern for labeled macro calls under
kCCBuiltins (per Phase 3 Task 3.3 decision note). The call site:

- Declares local 'bool' flags (one per label) and 'T' slots (one per
  label-value parameter), zero-initialized.
- Calls the macro via CCName(), appending &flag and &slot pointers
  after the value args (one group per label).
- After the call, dispatches with 'if (flag_<label>) goto <block>;'
  for each label, then falls through via EmitGoto to the return
  continuation.

catch_block handling (runtime exceptions) is deferred - Phase 4+.
Mirrors the structural pattern of csa-generator.cc:368-488 but
replaces CodeAssemblerLabel / TypedCodeAssemblerVariable with plain
bool/T locals and ca_.Goto with structured 'goto'.
---
 deps/v8/src/torque/cc-generator.cc | 115 ++++++++++++++++++++++++++++-
 1 file changed, 114 insertions(+), 1 deletion(-)

diff --git a/deps/v8/src/torque/cc-generator.cc b/deps/v8/src/torque/cc-generator.cc
index f6f17c04..9b452f95 100644
--- a/deps/v8/src/torque/cc-generator.cc
+++ b/deps/v8/src/torque/cc-generator.cc
@@ -315,7 +315,120 @@ void CCGenerator::EmitInstruction(const CallCsaMacroInstruction& instruction,
 void CCGenerator::EmitInstruction(
     const CallCsaMacroAndBranchInstruction& instruction,
     Stack<std::string>* stack) {
-  ReportError("Not supported in C++ output: CallCsaMacroAndBranch");
+  // Mirrors CSAGenerator::EmitInstruction(CallCsaMacroAndBranchInstruction)
+  // at csa-generator.cc:368-488 but lowered to plain C++ (kCCBuiltins). The
+  // out-param rewrite:
+  //   - For each label L_i: declare `bool flag_i = false;` and per
+  //     label-value parameter `T slot_i_j{};`.
+  //   - Invoke the macro via CCName() passing the usual value args followed
+  //     by trailing `&flag_i, &slot_i_j` pointer groups (one group per
+  //     label).
+  //   - After the call, dispatch on `if (flag_i) goto <label_block>;` for
+  //     each label, then fall through via EmitGoto to the return
+  //     continuation.
+  //
+  // `catch_block` (runtime exception propagation) is deferred — matches the
+  // Phase 2 treatment of CallRuntime / CallBuiltin.
+  if (instruction.catch_block) {
+    ReportError(
+        "Phase 3: CallCsaMacroAndBranch with catch block (exception "
+        "handling) is deferred.");
+  }
+
+  TypeVector parameter_types =
+      instruction.macro->signature().parameter_types.types;
+  std::vector<std::string> args = ProcessArgumentsCommon(
+      parameter_types, instruction.constexpr_arguments, stack);
+
+  Stack<std::string> pre_call_stack = *stack;
+
+  // Declare return-value locals if the macro returns something.
+  std::vector<std::string> results;
+  const Type* return_type = instruction.macro->signature().return_type;
+  if (return_type != TypeOracle::GetNeverType()) {
+    const auto lowered = LowerType(return_type);
+    for (std::size_t i = 0; i < lowered.size(); ++i) {
+      results.push_back(
+          DefinitionToVariable(instruction.GetValueDefinition(i)));
+      decls() << "  " << lowered[i]->GetRuntimeType() << " "
+              << results.back() << "{};  USE(" << results.back() << ");\n";
+    }
+  }
+
+  // Declare branch flags + per-label-value slots, and bind each label-value
+  // DefinitionLocation to its slot name so EmitGoto sees the right values
+  // when it emits phi-assignments into the label block.
+  std::vector<std::string> label_flag_names;
+  std::vector<std::vector<std::string>> label_value_names;
+  const LabelDeclarationVector& labels =
+      instruction.macro->signature().labels;
+  DCHECK_EQ(labels.size(), instruction.label_blocks.size());
+  for (size_t i = 0; i < labels.size(); ++i) {
+    std::string flag = FreshLabelName();
+    label_flag_names.push_back(flag);
+    decls() << "  bool " << flag << " = false;\n";
+    label_value_names.push_back({});
+    for (size_t j = 0; j < labels[i].types.size(); ++j) {
+      std::string val = FreshNodeName();
+      label_value_names[i].push_back(val);
+      const auto def = instruction.GetLabelValueDefinition(i, j);
+      SetDefinitionVariable(def, val);
+      decls() << "  " << labels[i].types[j]->GetRuntimeType() << " "
+              << val << "{};  USE(" << val << ");\n";
+    }
+  }
+
+  // Assemble the full argument list: value args followed by trailing
+  // pointer pairs, one group (&flag, &slot0, &slot1, ...) per label.
+  std::vector<std::string> all_args = args;
+  for (size_t i = 0; i < labels.size(); ++i) {
+    all_args.push_back("&" + label_flag_names[i]);
+    for (const auto& v : label_value_names[i]) {
+      all_args.push_back("&" + v);
+    }
+  }
+
+  // Emit the call.
+  out() << "  ";
+  if (return_type->StructSupertype().has_value()) {
+    out() << "std::tie(";
+    PrintCommaSeparatedList(out(), results);
+    out() << ") = ";
+  } else if (results.size() == 1) {
+    out() << results[0] << " = ";
+  }
+  // CCName() handles both ExternMacro (TorqueRuntimeMacroShims::...::Foo)
+  // and TorqueMacro (TqRuntime_<ExternalName>) via virtual dispatch —
+  // consistent with Phase 2's CallCsaMacroInstruction emission.
+  out() << instruction.macro->CCName() << "(";
+  PrintCommaSeparatedList(out(), all_args);
+  if (return_type->StructSupertype().has_value()) {
+    out() << ").Flatten();\n";
+  } else {
+    out() << ");\n";
+  }
+
+  // Dispatch: for each label, if the callee set its flag, goto the label
+  // block. The label-value slots are already bound to their
+  // DefinitionLocations via SetDefinitionVariable above, so EmitGoto's
+  // phi-rewrite sees them when we push their names onto the stack.
+  for (size_t i = 0; i < labels.size(); ++i) {
+    out() << "  if (" << label_flag_names[i] << ") {\n";
+    Stack<std::string> label_stack = pre_call_stack;
+    for (const auto& v : label_value_names[i]) {
+      label_stack.Push(v);
+    }
+    EmitGoto(instruction.label_blocks[i], &label_stack, "    ");
+    out() << "  }\n";
+  }
+
+  // Fallthrough: emit the return continuation. The `results` values are
+  // pushed onto the stack alongside any pre-existing entries so phi
+  // assignments in the continuation block see them.
+  if (instruction.return_continuation) {
+    for (const auto& r : results) stack->Push(r);
+    EmitGoto(*instruction.return_continuation, stack, "  ");
+  }
 }
 
 void CCGenerator::EmitInstruction(const MakeLazyNodeInstruction& instruction,
