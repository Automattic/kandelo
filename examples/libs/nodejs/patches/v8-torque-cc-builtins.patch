+    const auto& whitelist = GlobalContext::cc_builtins_whitelist();
+    if (whitelist.find(builtin->ExternalName()) == whitelist.end()) {
+      // Phase 1 stub path — byte-identical to Phase 1 for non-whitelisted
+      // builtins. The regression gate requires this text to not change.
+      csa_ccfile() << "// Builtin: " << builtin->ExternalName() << "\n"
+                   << "// (Phase 1 stub — body intentionally empty)\n"
+                   << "// void Builtin_" << builtin->ExternalName()
+                   << "(Isolate* isolate /* + args */);\n\n";
+      return;
+    }
+    if (builtin->IsJavaScript()) {
+      // JS-linkage builtins (receiver/newTarget/dispatchHandle parameter
+      // unpacking + Descriptor machinery) are deferred to Phase 3. Emit a
+      // marker comment so inspectors can see the builtin was whitelisted but
+      // intentionally skipped at this phase.
+      csa_ccfile() << "// Builtin: " << builtin->ExternalName()
+                   << " (JS linkage deferred to Phase 3)\n\n";
+      return;
+    }
+
+    // Real emission: non-JS-linkage builtin (`Builtin::Kind::kStub`) driven
+    // through CCGenerator. Mirrors the CSA pattern below (scopes, parameter
+    // binding, Visit(body), EmitGraph) but emits a plain C++ free function
+    // signature instead of TF_BUILTIN, and uses CCGenerator in place of
+    // CSAGenerator.
+    CurrentScope::Scope current_scope(builtin);
+    CurrentCallable::Scope current_callable(builtin);
+    CurrentReturnValue::Scope current_return_value;
+
+    const std::string& name = builtin->ExternalName();
+    const Signature& signature = builtin->signature();
+
+    // Emit C++ function signature: <ReturnType> Builtin_<Name>(Isolate*, ...).
+    csa_ccfile() << signature.return_type->GetRuntimeType() << " Builtin_"
+                 << name << "(Isolate* isolate";
+    for (size_t i = 0; i < signature.parameter_names.size(); ++i) {
+      const Type* param_type = signature.types()[i];
+      const std::string& param_name = signature.parameter_names[i]->value;
+      csa_ccfile() << ", " << param_type->GetRuntimeType() << " " << param_name;
+    }
+    csa_ccfile() << ") {\n"
+                 << "  USE(isolate);\n";
+
+    Stack<const Type*> parameter_types;
+    Stack<std::string> parameters;
+
+    BindingsManagersScope bindings_managers_scope;
+    BlockBindings<LocalValue> parameter_bindings(&ValueBindingsManager::Get());
+
+    // Populate parameter bindings using the shared AddParameter helper. This
+    // pushes "parameterN" names into the `parameters` stack and registers
+    // LocalValue bindings so Visit(body) can look them up by Torque name.
+    //
+    // TODO(phase-later): the bridge line below (`<Type> parameterN =
+    // <torque_name>;`) exists because AddParameter hard-codes the
+    // "parameterN" stack convention that CCGenerator's EmitGraph expects.
+    // A cleaner design would teach AddParameter an override-name mode so
+    // we can use the Torque names directly in the generated C++. Deferred
+    // to a future phase since it would touch the kCSA path too.
+    for (size_t i = 0; i < signature.parameter_names.size(); ++i) {
+      const bool mark_as_used = signature.implicit_count > i;
+      std::string var =
+          AddParameter(i, builtin, &parameters, &parameter_types,
+                       &parameter_bindings, mark_as_used);
+      const Type* type = signature.types()[i];
+      // Bridge from the C++ signature name (Torque parameter_names[i]->value)
+      // to the internal `parameterN` name that CCGenerator's EmitGraph uses.
+      csa_ccfile() << "  " << type->GetRuntimeType() << " " << var << " = "
+                   << signature.parameter_names[i]->value << ";\n";
+      csa_ccfile() << "  USE(" << var << ");\n";
+    }
+
+    assembler_ = CfgAssembler(parameter_types);
+    const Type* body_result = Visit(*builtin->body());
+    if (body_result != TypeOracle::GetNeverType()) {
+      ReportError("control reaches end of builtin, expected return of a value");
+    }
+    CCGenerator cc_generator{assembler().Result(), csa_ccfile()};
+    cc_generator.EmitGraph(parameters);
+    assembler_ = std::nullopt;
+    csa_ccfile() << "}\n\n";
     return;
   }
   CurrentScope::Scope current_scope(builtin);
