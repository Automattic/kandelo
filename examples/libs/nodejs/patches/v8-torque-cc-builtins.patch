From a169621decd09c5fa78dbaff267c3887c94b757b Mon Sep 17 00:00:00 2001
From: wasm-posix-kernel build <build@wasm-posix-kernel.local>
Date: Mon, 20 Apr 2026 23:34:03 -0400
Subject: [PATCH 04/10] torque: Builtin::ShouldBeInlined returns false for
 kCCBuiltins

---
 deps/v8/src/torque/declarable.h | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/deps/v8/src/torque/declarable.h b/deps/v8/src/torque/declarable.h
index aabca60b..c6a3639c 100644
--- a/deps/v8/src/torque/declarable.h
+++ b/deps/v8/src/torque/declarable.h
@@ -317,6 +317,9 @@ class Callable : public Scope {
   std::optional<Statement*> body() const { return body_; }
   bool IsExternal() const { return !body_.has_value(); }
   virtual bool ShouldBeInlined(OutputType output_type) const {
+    // In the kCCBuiltins pass, only Builtin declarables produce output;
+    // all other callables are suppressed by being "inlined" (i.e., skipped).
+    if (output_type == OutputType::kCCBuiltins) return true;
     // C++ output doesn't support exiting to labels, so functions with labels in
     // the signature must be inlined.
     return output_type == OutputType::kCC && !signature().labels.empty();
@@ -515,6 +518,10 @@ class Builtin : public Callable {
   bool HasCustomInterfaceDescriptor() const {
     return flags_ & Flag::kCustomInterfaceDescriptor;
   }
+  bool ShouldBeInlined(OutputType output_type) const override {
+    if (output_type == OutputType::kCCBuiltins) return false;
+    return Callable::ShouldBeInlined(output_type);
+  }
 
  private:
   friend class Declarations;
-- 
