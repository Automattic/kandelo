 1 file changed, 32 insertions(+)

diff --git a/deps/v8/src/torque/runtime-macro-shims.h b/deps/v8/src/torque/runtime-macro-shims.h
index a91bc9b5..e772d57f 100644
--- a/deps/v8/src/torque/runtime-macro-shims.h
+++ b/deps/v8/src/torque/runtime-macro-shims.h
@@ -11,6 +11,8 @@
 #include <cmath>
 #include <cstdint>
 
+#include "src/heap/factory.h"
+#include "src/numbers/conversions-inl.h"
 #include "src/numbers/integer-literal.h"
 #include "src/objects/casting.h"
 #include "src/objects/heap-object.h"
@@ -153,6 +155,36 @@ inline bool IsBigInt(Tagged<HeapObject> o) {
   return v8::internal::IsBigInt(o);
 }
 
+// Phase 8 Task 8.2 — shim for base.tq:1177 `extern macro
+// ConstexprIntegerLiteralToFloat64(constexpr IntegerLiteral): float64;`.
+// Used by `TqRuntimeFromConstexpr_Number_constexpr_IntegerLiteral_0`
+// (Increment's `tail Add(n, 1)` lowers `1` through this).
+inline double ConstexprIntegerLiteralToFloat64(const IntegerLiteral& i) {
+  return i.To<double>();
+}
+
+// Phase 8 Task 8.2 — shim for base.tq:1377 `extern macro
+// NumberConstant(constexpr float64): Number;`. Same call site as the
+// IntegerLiteralToFloat64 shim above; produces a Smi (when value fits)
+// or HeapNumber. Mirrors CSA's NumberConstant.
+inline Tagged<Number> NumberConstant(double v) {
+  int smi_value;
+  if (DoubleToSmiInteger(v, &smi_value)) {
+    return Cast<Number>(Smi::FromInt(smi_value));
+  }
+  Isolate* isolate = Isolate::Current();
+  return Cast<Number>(*isolate->factory()->NewHeapNumber(v));
+}
+
+// Phase 8 Task 8.2 — shim for base.tq:1335 `extern macro
+// SmiFromUint32(uint32): Smi;`. Used by
+// `TqRuntimeSmiTag_Operation_0` (the Operation::kIncrement enum lowers
+// to a uint32 and gets boxed as a Smi for runtime::BigIntUnaryOp).
+inline Tagged<Smi> SmiFromUint32(uint32_t v) {
+  // Operation enum values fit in Smi range; static_cast is sufficient.
+  return Smi::FromInt(static_cast<int>(v));
+}
+
 }  // namespace CodeStubAssembler
 }  // namespace TorqueRuntimeMacroShims
 }  // namespace internal
