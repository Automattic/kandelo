+void CCGenerator::EmitCatchBlockDispatch(
+    const Block* catch_block, const Stack<std::string>& pre_call_stack,
+    const std::optional<DefinitionLocation>& exception_object_definition) {
+  // Mirrors CSAGenerator::PostCallableExceptionPreparation
+  // (csa-generator.cc:672-711) but lowered to plain C++:
+  //   - CSA opens a ScopedExceptionHandler around the call and binds
+  //     the caught exception via ca_.Bind(label, &<var>) on the
+  //     deferred catch label, then ca_.Goto(catch_block, ..., <var>).
+  //   - We have no scoped handler in plain C++ — just check
+  //     `<isolate>->has_exception()` after the call. If set, capture
+  //     the exception value, clear the slot (so the host doesn't
+  //     re-rethrow), and EmitGoto to the catch block with the
+  //     exception value pushed as the trailing phi input.
+  // Under kCCBuiltins we use `Isolate::Current()` (Phase 8 convention,
+  // matches CallBuiltin's :570 substitution); the stock kCC path that
+  // doesn't generate full builtin bodies still uses `isolate`.
+  DCHECK(exception_object_definition.has_value());
+  const std::string exc_var =
+      DefinitionToVariable(*exception_object_definition);
+  decls() << "  Tagged<Object> " << exc_var << "{}; USE(" << exc_var << ");\n";
+  const char* isolate_token =
+      is_cc_builtins_ ? "Isolate::Current()" : "isolate";
+  out() << "  if (V8_UNLIKELY(" << isolate_token << "->has_exception())) {\n";
+  out() << "    " << exc_var << " = " << isolate_token << "->exception();\n";
+  out() << "    " << isolate_token << "->clear_internal_exception();\n";
+  Stack<std::string> catch_stack = pre_call_stack;
+  catch_stack.Push(exc_var);
+  EmitGoto(catch_block, &catch_stack, "    ");
+  out() << "  }\n";
+}
+
 void CCGenerator::EmitGoto(const Block* destination, Stack<std::string>* stack,
                            std::string indentation) {
   const auto& destination_definitions = destination->InputDefinitions();
