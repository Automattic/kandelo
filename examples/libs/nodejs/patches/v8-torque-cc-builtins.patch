+  // machinery that is not safe to re-enter under kCCBuiltins — they would
+  // drive CSAGenerator/assembler against state intended only for the kCSA
+  // first pass and crash (SIGSEGV) for NamespaceConstants, or emit stray
+  // cpp-file content for inlined macros. The kCC and kCCDebug passes avoid
+  // this by iterating curated macro lists; Phase 1 matches that pattern by
+  // filtering here. Phase 2 can widen this if additional declarable kinds
+  // need to drive kCCBuiltins emission.
   output_type_ = OutputType::kCCBuiltins;
   for (size_t i = 0; i < all_declarables.size(); ++i) {
+    if (all_declarables[i]->kind() != Declarable::kBuiltin) continue;
     try {
