+    // Forward declarations for the TqRuntime<name>_<N> macro functions
+    // whose inline bodies are appended to cc_builtins_ccfile by the
+    // kCCBuiltins fifth pass (Visit(TorqueMacro*) via VisitMacroCommon
+    // — see f.PrintDeclaration(csa_headerfile()) at line ~412).
