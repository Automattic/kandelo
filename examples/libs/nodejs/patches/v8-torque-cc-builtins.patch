From bf6edc87d24acc37c3e622ca4e0383218c7f2248 Mon Sep 17 00:00:00 2001
From: Brandon Payton <brandon@happycode.net>
Date: Sat, 25 Apr 2026 11:04:34 -0400
Subject: [PATCH 80/94] torque: emit Builtin_Add and Builtin_NonNumberToNumeric
 C bridges
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Phase 8 inline shims in the kCCBuiltins .cc preamble that fill the
TFC-builtin C-symbol gap. Both `Add` (number.tq:371 stub-linkage
overload) and `NonNumberToNumeric` (TFC) are CSA-emitted to native
code at snapshot time and have NO `Builtin_<Name>` C entry —
`nm libv8_*.a` confirms only `AddAssembler::GenerateAddImpl` lives
in the v8 archive, never a directly-callable `Builtin_Add`. The
kCCBuiltins emitter spells `Builtin_<Callee>(Isolate::Current(),
args...)` and trusts the linker, which previously failed for any
non-CPP callee.

Approach: emit inline definitions next to True_0/False_0 in the
preamble. Vague-linkage dedupe means each TU pays only its own
copy; total binary impact is single-digit KiB across the kCCBuiltins
TU set.

`Builtin_Add` covers the Number(Number, Number)→Number overload
that Increment's `tail Add(n, 1)` hits. Implementation: native
int64 Smi arithmetic with overflow→HeapNumber; Smi/HeapNumber
double-arithmetic with re-tagging via DoubleToSmiInteger. Full
ECMA Add (string concat, BigInt, ToPrimitive) is unaffected — that
still lives in the CSA-emitted Add Code object reached via V8's
normal builtin dispatch (e.g., when JS does `a + b` outside a
kCCBuiltins flow).

`Builtin_NonNumberToNumeric` wraps Object::ToNumeric, which
implements the spec ECMAScript ToNumeric. Used by UnaryOp1's
JSAnyNotNumeric arm (string→Number, bool→Smi, null/undefined→0/NaN,
object→ToPrimitive→recurse). Symbol input throws TypeError per
spec — we UNREACHABLE because catch_block is still deferred.
No inner HandleScope: the outer JS-linkage adaptor provides one,
and an inner scope would invalidate the returned Tagged on close.

Together with cc-generator.cc's Isolate::Current() substitution
(prior commit) this unblocks Increment as the first real-world
tail-call forcing target for the Phase-7 emitter branch.
---
 deps/v8/src/torque/implementation-visitor.cc | 69 ++++++++++++++++++++
 deps/v8/src/torque/runtime-macro-shims.h     |  7 +-
 2 files changed, 74 insertions(+), 2 deletions(-)

diff --git a/deps/v8/src/torque/implementation-visitor.cc b/deps/v8/src/torque/implementation-visitor.cc
index 96e0bc1b..6cc0e7bc 100644
--- a/deps/v8/src/torque/implementation-visitor.cc
+++ b/deps/v8/src/torque/implementation-visitor.cc
@@ -2238,6 +2238,75 @@ void ImplementationVisitor::GenerateImplementation(const std::string& dir) {
         "  return Cast<False>(\n"
         "      ReadOnlyRoots(Isolate::Current()).false_value());\n"
         "}\n"
+        "\n"
+        "// Phase 8 — TFC builtin C bridges. `Add` and `NonNumberToNumeric`\n"
+        "// are TFC (Torque, Function, Custom-call-descriptor) builtins —\n"
+        "// CSA-emitted to native code at snapshot time, NO `Builtin_<Name>`\n"
+        "// C symbol exists in any v8 lib. The kCCBuiltins emitter spells\n"
+        "// `Builtin_<Callee>(Isolate::Current(), args...)` at call sites,\n"
+        "// so we provide inline C functions here that wrap V8's high-level\n"
+        "// APIs (Object::ToNumeric, direct Number+Number arithmetic). The\n"
+        "// inline'd definition lives in every kCCBuiltins .cc TU; the\n"
+        "// linker dedupes via vague linkage. catch_block is deferred (Phase\n"
+        "// 9+), so the rare Symbol-input branch of NonNumberToNumeric\n"
+        "// UNREACHABLEs instead of throwing TypeError.\n"
+        "//\n"
+        "// `Builtin_Add` covers only the Number(Number, Number) overload\n"
+        "// declared at number.tq:371 — the path Increment's `tail Add(n, 1)`\n"
+        "// hits, where both operands are Smi|HeapNumber. Full ECMA Add\n"
+        "// (string concat / BigInt / ToPrimitive) lives in the\n"
+        "// CSA-emitted Add Code object and is unaffected by this shim.\n"
+        "inline Tagged<Number> Builtin_Add(Isolate* isolate,\n"
+        "                                  Tagged<Context> context,\n"
+        "                                  Tagged<Number> left,\n"
+        "                                  Tagged<Number> right) {\n"
+        "  USE(context);\n"
+        "  if (IsSmi(left) && IsSmi(right)) {\n"
+        "    int64_t l = static_cast<int64_t>(Cast<Smi>(left).value());\n"
+        "    int64_t r = static_cast<int64_t>(Cast<Smi>(right).value());\n"
+        "    int64_t sum = l + r;\n"
+        "    if (Smi::IsValid(sum)) {\n"
+        "      return Cast<Number>(Smi::FromInt(static_cast<int>(sum)));\n"
+        "    }\n"
+        "    return Cast<Number>(\n"
+        "        *isolate->factory()->NewHeapNumber(static_cast<double>(sum)));\n"
+        "  }\n"
+        "  double l = IsSmi(left)\n"
+        "      ? static_cast<double>(Cast<Smi>(left).value())\n"
+        "      : Cast<HeapNumber>(left)->value();\n"
+        "  double r = IsSmi(right)\n"
+        "      ? static_cast<double>(Cast<Smi>(right).value())\n"
+        "      : Cast<HeapNumber>(right)->value();\n"
+        "  double sum = l + r;\n"
+        "  int smi_value;\n"
+        "  if (DoubleToSmiInteger(sum, &smi_value)) {\n"
+        "    return Cast<Number>(Smi::FromInt(smi_value));\n"
+        "  }\n"
+        "  return Cast<Number>(*isolate->factory()->NewHeapNumber(sum));\n"
+        "}\n"
+        "\n"
+        "// `Builtin_NonNumberToNumeric` wraps Object::ToNumeric, which\n"
+        "// implements ECMAScript ToNumeric (string parse, boolean→Smi,\n"
+        "// null/undefined coercion, ToPrimitive recurse). Symbol inputs\n"
+        "// throw TypeError under spec — we UNREACHABLE because the\n"
+        "// kCCBuiltins emitter has no exception path yet (Phase 9+).\n"
+        "// Call sites in kCCBuiltins emission (UnaryOp1's JSAnyNotNumeric\n"
+        "// arm) only feed JSAnyNotNumeric inputs here, so Number/BigInt\n"
+        "// short-circuit before reaching this shim.\n"
+        "inline Tagged<Numeric> Builtin_NonNumberToNumeric(\n"
+        "    Isolate* isolate, Tagged<Context> context,\n"
+        "    Tagged<JSAny> input) {\n"
+        "  USE(context);\n"
+        "  // No inner HandleScope — the outer JS-linkage adaptor frame\n"
+        "  // already provides one. An inner scope would invalidate the\n"
+        "  // returned Tagged on close.\n"
+        "  Handle<JSAny> input_handle(input, isolate);\n"
+        "  DirectHandle<Object> result;\n"
+        "  if (!Object::ToNumeric(isolate, input_handle).ToHandle(&result)) {\n"
+        "    UNREACHABLE();  // Symbol input → TypeError; catch_block deferred.\n"
+        "  }\n"
+        "  return Cast<Numeric>(*result);\n"
+        "}\n"
         "\n";
     std::string cc_builtins_postamble = "\n}  // namespace v8::internal\n";
     WriteFile(base_filename + "-tq-ccbuiltins.cc",
diff --git a/deps/v8/src/torque/runtime-macro-shims.h b/deps/v8/src/torque/runtime-macro-shims.h
index e772d57f..aa93569c 100644
--- a/deps/v8/src/torque/runtime-macro-shims.h
+++ b/deps/v8/src/torque/runtime-macro-shims.h
@@ -158,9 +158,12 @@ inline bool IsBigInt(Tagged<HeapObject> o) {
 // Phase 8 Task 8.2 — shim for base.tq:1177 `extern macro
 // ConstexprIntegerLiteralToFloat64(constexpr IntegerLiteral): float64;`.
 // Used by `TqRuntimeFromConstexpr_Number_constexpr_IntegerLiteral_0`
-// (Increment's `tail Add(n, 1)` lowers `1` through this).
+// (Increment's `tail Add(n, 1)` lowers `1` through this). IntegerLiteral
+// only exposes To<integral-type>(); we go via int64_t and let the
+// implicit double conversion handle magnitudes up to 2^53. Increment's
+// only literal here is "1", which is trivially representable.
