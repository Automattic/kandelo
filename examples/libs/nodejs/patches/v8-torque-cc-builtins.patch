From 9b794e1fa4b383e86fdc0d46f818c44f8fe78857 Mon Sep 17 00:00:00 2001
From: wasm-posix-kernel build <build@wasm-posix-kernel.local>
Date: Tue, 21 Apr 2026 14:08:09 -0400
Subject: [PATCH 23/27] torque: ExternMacro + Intrinsic ShouldBeInlined return
 false for kCCBuiltins
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Phase 2 holes surfaced by Phase 3 Task 3.4 probing.

(1) ExternMacro: the base Callable::ShouldBeInlined returns true for
kCCBuiltins, which routes every extern-macro call through InlineMacro.
InlineMacro dereferences macro->body() (std::nullopt for ExternMacro),
causing a null-pointer SIGSEGV in Visit(Statement*) at
implementation-visitor.cc:58. The override mirrors Phase 2's same fix
for RuntimeFunction (both have no body; inline-lowering is meaningless).
The call now takes the non-inline path and emits CallCsaMacroInstruction
or CallCsaMacroAndBranchInstruction, which CCGenerator handles.

(2) Intrinsic: the same default-true path under kCCBuiltins leaves
GenerateCall's `inline_macro` local true for intrinsic callees. When
`inline_macro` is true, AddCallParameter does NOT push the converted
value's constexpr_value() into `constexpr_arguments`. That vector stays
empty. Intrinsic handlers (e.g. %MakeLazy, %SizeOf, %RawConstexprCast,
%IndexedFieldLength, %FieldSlice) then index into constexpr_arguments[0]
— out-of-bounds read → SIGSEGV in StringLiteralUnquote at
implementation-visitor.cc:3272. Force the non-inline path so intrinsic
handlers see the arguments they require.

Both overrides only affect kCCBuiltins; CSA / kCC / kCCDebug behavior
is unchanged.
---
 deps/v8/src/torque/declarable.h | 26 ++++++++++++++++++++++++++
 1 file changed, 26 insertions(+)

diff --git a/deps/v8/src/torque/declarable.h b/deps/v8/src/torque/declarable.h
index 202bdcb6..4c40c0d8 100644
--- a/deps/v8/src/torque/declarable.h
+++ b/deps/v8/src/torque/declarable.h
@@ -416,6 +416,17 @@ class ExternMacro : public Macro {
     return external_assembler_name_;
   }
 
+  bool ShouldBeInlined(OutputType output_type) const override {
+    // Extern macros have no Torque body (body() == std::nullopt), so the
+    // base Callable::ShouldBeInlined default of `true` under kCCBuiltins
+    // would route the call through InlineMacro, which null-derefs
+    // macro->body() in Visit(Statement*). Force the non-inline path so
+    // CallCsaMacroInstruction / CallCsaMacroAndBranchInstruction handle
+    // it — mirrors RuntimeFunction::ShouldBeInlined.
+    if (output_type == OutputType::kCCBuiltins) return false;
+    return Callable::ShouldBeInlined(output_type);
+  }
+
   std::string CCName() const override {
     return "TorqueRuntimeMacroShims::" + external_assembler_name() +
            "::" + ExternalName();
@@ -565,6 +576,21 @@ class Intrinsic : public Callable {
  public:
   DECLARE_DECLARABLE_BOILERPLATE(Intrinsic, intrinsic)
 
+  bool ShouldBeInlined(OutputType output_type) const override {
+    // Intrinsics have no Torque body (body() == std::nullopt); they are
+    // handled specially in GenerateCall's intrinsic switch, which reads
+    // `constexpr_arguments` populated only when `inline_macro == false`.
+    // The base Callable default of `true` under kCCBuiltins leaves
+    // `constexpr_arguments` empty and causes intrinsic handlers that
+    // index into it (e.g. `%MakeLazy`, `%SizeOf`, `%RawConstexprCast`)
+    // to read past the end — SIGSEGV in StringLiteralUnquote. Force the
+    // non-inline path so AddCallParameter populates constexpr_arguments
+    // before the intrinsic handler runs. Mirrors RuntimeFunction /
+    // ExternMacro ShouldBeInlined overrides.
+    if (output_type == OutputType::kCCBuiltins) return false;
+    return Callable::ShouldBeInlined(output_type);
+  }
+
  private:
   friend class Declarations;
   Intrinsic(std::string name, const Signature& signature)
