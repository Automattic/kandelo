From 2bf63c6fbac7eced4ff43303cc535b6e6314c009 Mon Sep 17 00:00:00 2001
From: Brandon Payton <brandon@happycode.net>
Date: Fri, 24 Apr 2026 12:31:54 -0400
Subject: [PATCH 63/94] torque: CCGenerator emits UncheckedCast for UnsafeCast
 on Tagged types
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Under kCCBuiltins, typeswitch arms lower to UnsafeCastInstruction
after each arm's input type is narrowed (e.g. NumberIsFinite: after
the Smi arm, the remaining type is JSAny minus Smi, rendered as
Tagged<Union<BigInt,Boolean,HeapNumber,JSReceiver,...>>). The prior
emission used static_cast<Tagged<T>>(...) which C++ rejects:

  error: no matching conversion for static_cast from 'Tagged<JSAny>'
  to 'Tagged<Union<BigInt,Boolean,HeapNumber,...>>'

Tagged<U> → Tagged<T> isn't a subtype conversion — it's an explicit
unchecked narrowing. Route through UncheckedCast<T>(x) instead,
matching %RawDownCast's path added in Phase 5 Task 5.8 (commit
744f948a).

Gated on is_cc_builtins_ so stock kCC output stays byte-identical;
non-Tagged types (enums, integrals, raw pointers) keep the
static_cast path.
---
 deps/v8/src/torque/cc-generator.cc | 21 ++++++++++++++++++---
 1 file changed, 18 insertions(+), 3 deletions(-)

diff --git a/deps/v8/src/torque/cc-generator.cc b/deps/v8/src/torque/cc-generator.cc
index 9e496eef..9f34f9c1 100644
--- a/deps/v8/src/torque/cc-generator.cc
+++ b/deps/v8/src/torque/cc-generator.cc
@@ -796,9 +796,24 @@ void CCGenerator::EmitInstruction(const AbortInstruction& instruction,
 
 void CCGenerator::EmitInstruction(const UnsafeCastInstruction& instruction,
                                   Stack<std::string>* stack) {
-  const std::string str = "static_cast<" +
-                          instruction.destination_type->GetRuntimeType() +
-                          ">(" + stack->Top() + ")";
+  std::string str;
+  // Under kCCBuiltins, narrowing between two Tagged<T> types (typeswitch
+  // arms lower to UnsafeCastInstruction; the lowered type after a Smi
+  // arm is `JSAny minus Smi`, which is still Tagged) cannot use C++
+  // static_cast — Tagged<U> → Tagged<T> isn't a subtype conversion.
+  // Emit UncheckedCast<T>(x) instead, matching %RawDownCast's path.
+  // Gated on is_cc_builtins_ so stock kCC output (which doesn't build
+  // full builtin bodies) stays byte-identical.
+  if (is_cc_builtins_ &&
+      instruction.destination_type->IsSubtypeOf(TypeOracle::GetTaggedType()) &&
+      !instruction.destination_type->StructSupertype()) {
+    str = "UncheckedCast<" +
+          instruction.destination_type->GetGeneratedTNodeTypeName() + ">(" +
+          stack->Top() + ")";
+  } else {
+    str = "static_cast<" + instruction.destination_type->GetRuntimeType() +
+          ">(" + stack->Top() + ")";
+  }
   stack->Poke(stack->AboveTop() - 1, str);
   SetDefinitionVariable(instruction.GetValueDefinition(), str);
 }
