+// Copyright 2026 Node.js contributors. All rights reserved.
+// Phase 4 smoke test for the Torque CC backend.
+//
+// Proves that a Torque builtin whose source lives at
+// deps/v8/test/torque-cc-fixtures/return.tq can be translated
+// via the --cc-builtins-whitelist=TorqueCcTest_Return flag, compiled
+// into libv8, linked into Node's cctest binary, and invoked by C++.
+// The Phase 4 host build configures the whitelist via GYP_DEFINES
+// (see examples/libs/nodejs/build-v8-host-phase4.sh).
+
+#include "gtest/gtest.h"
+#include "node_test_fixture.h"
+
+// V8 internal headers required to describe the builtin signature and
+// to look it up via the kCCBuiltins dispatch table. We keep the set
+// minimal and avoid *-inl.h files because Node.js's build config
+// (V8_LITE_MODE + disabled features) conflicts with some inline
+// headers, but plain declarations are fine.
+#include "src/builtins/builtins.h"
+#include "src/objects/contexts.h"
+#include "src/objects/smi.h"
+#include "src/objects/tagged.h"
+
+namespace v8 {
+namespace internal {
+
+// Forward declaration matches the kCCBuiltins emission at
+// out/<Cfg>/gen/torque-generated/test/torque-cc-fixtures/return-tq-ccbuiltins.cc.
+// Default (C++) linkage — the generator emits a free function in
+// v8::internal without extern "C".
+Tagged<Smi> Builtin_TorqueCcTest_Return(Isolate* isolate,
+                                        Tagged<Context> context,
+                                        Tagged<Smi> arg);
+
+}  // namespace internal
+}  // namespace v8
+
+using TorqueCcBuiltinTest = NodeTestFixture;
+
+TEST_F(TorqueCcBuiltinTest, DirectInvocation) {
+  // The TorqueCcTest_Return builtin just passes its Smi argument
+  // through unchanged; it does not touch `isolate` or `context`. Pass
+  // a default-constructed Tagged<Context> (null tagged pointer) — this
+  // is only safe because the builtin's generated body ignores it.
+  v8::internal::Isolate* i_isolate =
+      reinterpret_cast<v8::internal::Isolate*>(isolate_);
+  v8::internal::Tagged<v8::internal::Context> null_context;
+
+  v8::internal::Tagged<v8::internal::Smi> input =
+      v8::internal::Smi::FromInt(42);
+  v8::internal::Tagged<v8::internal::Smi> result =
+      v8::internal::Builtin_TorqueCcTest_Return(
+          i_isolate, null_context, input);
+  EXPECT_EQ(v8::internal::Smi::ToInt(result), 42);
+}
+
+TEST_F(TorqueCcBuiltinTest, DispatchTableLookup) {
+  // The generated dispatch table should resolve Builtin::k<Name>
+  // to the same address as &Builtin_<Name>. Note: this test requires
+  // the cctest target's defines (V8_LITE_MODE, V8_ENABLE_LEAPTIERING,
+  // ...) to match v8_base_without_compiler's; otherwise the Builtin
+  // enum ordering differs across translation units and the switch
+  // lookup compares against a stale integer. See node.gyp's cctest
+  // target for the synchronised define set.
+  v8::internal::Address direct = reinterpret_cast<v8::internal::Address>(
+      &v8::internal::Builtin_TorqueCcTest_Return);
+  v8::internal::Address via_table = v8::internal::Builtins::TorqueCcEntryOf(
+      v8::internal::Builtin::kTorqueCcTest_Return);
+  EXPECT_EQ(direct, via_table);
+}
