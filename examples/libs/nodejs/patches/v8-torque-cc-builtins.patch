@@ -29,12 +29,21 @@ class CCGenerator : public TorqueCodeGenerator {
 
   void SetReturnMode(ReturnMode mode) { return_mode_ = mode; }
 
+  // Set when the enclosing function has a non-void return type, so the
+  // GotoExternalInstruction label-exit emission can use `return {};`
+  // instead of bare `return;` (which is ill-formed for non-void
+  // functions). Set by VisitMacroCommon before EmitGraph.
+  void SetExternalGotoReturnsValue(bool v) {
+    external_goto_returns_value_ = v;
+  }
+
   static void EmitCCValue(VisitResult result, const Stack<std::string>& values,
                           std::ostream& out);
 
  private:
   bool is_cc_debug_;
   ReturnMode return_mode_ = ReturnMode::kDirect;
+  bool external_goto_returns_value_ = false;
 
   void EmitSourcePosition(SourcePosition pos,
                           bool always_emit = false) override;
