#!/bin/bash
# Worktree-local SDK dispatcher.
#
# Every SDK CLI tool (wasm{32,64}posix-{cc,c++,ar,ranlib,nm,strip,
# pkg-config,configure}) is a symlink to this script. We read $0 to
# pick the right TypeScript entry point and forward via Node, exporting
# WASM_POSIX_INVOKED_AS so detectArch() knows which arch was requested
# (the symlink's own basename, not whatever Node sees in argv[1]).
#
# This replaces the global `npm link` pattern: build scripts source
# sdk/activate.sh to put this directory on PATH, so each worktree's
# build scripts use that worktree's own SDK source. No global state.
set -e

NAME="$(basename "$0")"

# Strip the arch prefix to get the bare command name.
COMMAND="${NAME#wasm32posix-}"
COMMAND="${COMMAND#wasm64posix-}"

case "$COMMAND" in
    cc)         SCRIPT="cc.ts" ;;
    c++)        SCRIPT="c++.ts" ;;
    ar)         SCRIPT="ar.ts" ;;
    ranlib)     SCRIPT="ranlib.ts" ;;
    nm)         SCRIPT="nm.ts" ;;
    strip)      SCRIPT="strip.ts" ;;
    pkg-config) SCRIPT="pkg-config.ts" ;;
    configure)  SCRIPT="configure.ts" ;;
    *)
        echo "unknown SDK command: $COMMAND (invoked as $NAME)" >&2
        exit 2
        ;;
esac

DISPATCH_DIR="$(cd "$(dirname "$0")" && pwd)"
exec env "WASM_POSIX_INVOKED_AS=$NAME" \
    node --experimental-strip-types "$DISPATCH_DIR/../src/bin/$SCRIPT" "$@"
