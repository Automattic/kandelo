{
  "version": 1,
  "profiles": {
    "shell": {
      "presentation": {
        "bootPrimary": "syslog",
        "runningPrimary": [
          "terminal",
          "syslog"
        ],
        "terminalAccess": "primary",
        "internalsAccess": "drawer"
      },
      "guide": {
        "title": "Shell demo",
        "summary": "Snippets and scripts are delivered through the same PTY-backed shell the user sees.",
        "groups": [
          {
            "title": "Snippets",
            "actions": [
              {
                "id": "hello",
                "label": "Hello",
                "description": "Print a short line from bash.",
                "kind": "terminal.run",
                "payload": "echo \"hello from Kandelo\""
              },
              {
                "id": "pipe",
                "label": "Pipe",
                "description": "Run a small pipe through coreutils.",
                "kind": "terminal.run",
                "payload": "printf \"alpha\\nbeta\\ngamma\\n\" | grep a | wc -l"
              },
              {
                "id": "files",
                "label": "Files",
                "description": "Write and read a temporary file.",
                "kind": "terminal.run",
                "payload": "echo test > /tmp/f.txt && cat /tmp/f.txt"
              }
            ]
          },
          {
            "title": "Raw input",
            "actions": [
              {
                "id": "type-ls",
                "label": "Type ls",
                "description": "Send keystrokes into the current terminal.",
                "kind": "terminal.write",
                "payload": "ls /usr/bin | head\n"
              }
            ]
          }
        ],
        "script": {
          "title": "Batch script",
          "language": "sh",
          "initialText": "echo \"Hello from a Kandelo guided script\"\nuname -a\necho \"---\"\nprintf \"cwd: \"; pwd\nprintf \"files in /tmp before: \"; ls /tmp | wc -l\necho \"written by the demo guide\" > /tmp/kandelo-guide.txt\ncat /tmp/kandelo-guide.txt"
        },
        "companion": {
          "title": "Companion HTML",
          "srcDoc": "<!doctype html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <style>\n    :root { color-scheme: dark; }\n    body {\n      margin: 0;\n      padding: 12px;\n      background: #191512;\n      color: #f3d6b3;\n      font: 12px ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n    }\n    h1 {\n      margin: 0 0 8px;\n      font-size: 12px;\n      font-weight: 650;\n      letter-spacing: 0;\n      color: #fff2df;\n    }\n    p {\n      margin: 0 0 10px;\n      color: #b99d7d;\n      line-height: 1.4;\n    }\n    .row {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 6px;\n    }\n    button {\n      border: 1px solid rgba(255, 169, 86, 0.28);\n      background: rgba(255, 169, 86, 0.12);\n      color: #ffe0b9;\n      border-radius: 6px;\n      padding: 7px 9px;\n      font: inherit;\n      cursor: pointer;\n    }\n    button:hover { background: rgba(255, 169, 86, 0.2); }\n    #status {\n      min-height: 16px;\n      margin-top: 10px;\n      color: #d2b08b;\n      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\n      font-size: 11px;\n    }\n  </style>\n</head>\n<body>\n  <h1>Shell companion</h1>\n  <p>This frame has no kernel access. It can only request parent-approved action ids.</p>\n  <div class=\"row\"><button type=\"button\" data-action=\"hello\">Hello</button><button type=\"button\" data-action=\"files\">Files</button><button type=\"button\" data-action=\"type-ls\">Type input</button></div>\n  <div id=\"status\"></div>\n  <script>\n    const status = document.getElementById(\"status\");\n    document.addEventListener(\"click\", (event) => {\n      const button = event.target.closest(\"button[data-action]\");\n      if (!button) return;\n      const actionId = button.getAttribute(\"data-action\");\n      parent.postMessage({ type: \"kandelo.demoAction\", actionId }, \"*\");\n      status.textContent = \"sent \" + actionId;\n    });\n  </script>\n</body>\n</html>"
        }
      }
    },
    "doom": {
      "presentation": {
        "bootPrimary": "syslog",
        "runningPrimary": [
          "framebuffer",
          "terminal",
          "syslog"
        ],
        "terminalAccess": "drawer",
        "internalsAccess": "drawer",
        "autoCommand": "/usr/local/bin/fbdoom -iwad /doom1.wad"
      },
      "assets": [
        {
          "path": "/doom1.wad",
          "url": "https://cdn.jsdelivr.net/gh/gaborbata/vanilla-mocha-doom@15825a07a48806bcfb242a42afd5ee7cb3c9a3a4/wads/doom1.wad",
          "sha256": "1d7d43be501e67d927e415e0b8f3e29c3bf33075e859721816f652a526cac771",
          "mode": 420,
          "devCorsProxy": true
        }
      ]
    },
    "modeset": {
      "presentation": {
        "bootPrimary": "syslog",
        "runningPrimary": [
          "kms",
          "terminal",
          "syslog"
        ],
        "terminalAccess": "drawer",
        "internalsAccess": "drawer",
        "autoCommand": "/usr/local/bin/modeset"
      }
    }
  }
}
