{
  "private": true,
  "type": "module",
  "scripts": {
    "wordpress:build": "bash examples/wordpress/build.sh",
    "wordpress:serve": "npx tsx examples/wordpress/serve.ts",
    "wordpress:benchmark": "npx tsx examples/wordpress/perf/benchmark.ts",
    "bench": "npx tsx benchmarks/run.ts",
    "bench:browser": "npx tsx benchmarks/run.ts --host browser",
    "bench:compare": "npx tsx benchmarks/compare.ts",
    "pack:host": "npm --prefix host pack",
    "pack:sdk": "npm --prefix sdk pack",
    "pack:packages": "npm run pack:host && npm run pack:sdk"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "vite": "^8.0.3"
  }
}
